# App
APP_NAME=milo
NODE_ENV=development
SERVICE=monolith
FASTIFY_LOG_LEVEL=DEBUG
FASTIFY_PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5434
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=milo_dev
MIGRATE_ON_START=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_CLUSTER=false

# MinIO (local S3)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT=http://localhost:9010
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_ASSETS_BUCKET=milo-dev-assets
S3_DEPLOYMENTS_BUCKET=milo-dev-deployments
CDN_BASE_URL=http://localhost:9010

# Clerk auth
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_VERIFY_TOKENS=true

# LLM provider routing: openrouter | ollama
LLM_PROVIDER=openrouter

# OpenRouter (multi-provider, includes Claude/OpenAI/Gemini)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Ollama (self-hosted, open-weights only)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=

# Model selection per task.
# With LLM_PROVIDER=openrouter these are OpenRouter model IDs.
# With LLM_PROVIDER=ollama use Ollama-compatible model tags.
DEFAULT_LLM_MODEL=anthropic/claude-3.5-sonnet
VISION_LLM_MODEL=openai/gpt-4o
CHEAP_LLM_MODEL=google/gemini-flash-1.5

# Ollama equivalents (uncomment when LLM_PROVIDER=ollama):
# DEFAULT_LLM_MODEL=qwen2.5:32b
# VISION_LLM_MODEL=llava:34b
# CHEAP_LLM_MODEL=qwen2.5:7b

# GrowthBook feature flags (optional for PoC)
GROWTHBOOK_CLIENT_KEY=
GROWTHBOOK_API_HOST=https://cdn.growthbook.io
GROWTHBOOK_ENABLE_STREAMING=false