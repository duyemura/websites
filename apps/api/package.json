{
  "name": "@ploy-gyms/api",
  "version": "0.0.1",
  "private": true,
  "description": "Ploy for gyms — Fastify API and worker",
  "main": "dist/app.js",
  "type": "commonjs",
  "scripts": {
    "migrate:test": "DOTENV_CONFIG_PATH=./.env.test node -r dotenv/config ./node_modules/kysely-ctl/dist/bin.cjs migrate",
    "pretest": "pnpm build && pnpm migrate:test latest",
    "test": "DOTENV_CONFIG_PATH=./.env.test node -r dotenv/config ./node_modules/vitest/vitest.mjs --no-file-parallelism",
    "test:coverage": "vitest --coverage --watch=false --no-file-parallelism",
    "lint": "eslint .",
    "build": "tsc",
    "watch:ts": "tsc -w",
    "dev": "pnpm build && concurrently -k -p \"[{name}]\" -n \"TypeScript,App\" -c \"yellow.bold,cyan.bold\" \"pnpm:watch:ts\" \"pnpm:dev:start\"",
    "dev:start": "DOTENV_CONFIG_PATH=../../.env node -r dotenv/config ./node_modules/fastify-cli/cli.js start --ignore-watch='(.ts$|.json$)' -o -w -P dist/app.js",
    "start": "pnpm build && fastify start -o -P dist/app.js",
    "start:prod": "fastify start -o dist/app.js",
    "repl": "pnpm build && fastify start -o -P dist/app.js -- --repl",
    "migrate": "DOTENV_CONFIG_PATH=../../.env node -r dotenv/config ./node_modules/kysely-ctl/dist/bin.cjs migrate",
    "seed": "DOTENV_CONFIG_PATH=../../.env node -r dotenv/config ./node_modules/kysely-ctl/dist/bin.cjs seed",
    "codegen:db": "export $(grep -v '^#' ../../.env | xargs) && kysely-codegen --dialect postgres --out-file src/types/db.ts --camel-case --url=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@bull-board/api": "^6.7.10",
    "@bull-board/fastify": "^6.7.10",
    "@fastify/autoload": "^6.1.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/env": "^5.0.2",
    "@fastify/sensible": "^6.0.3",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.2",
    "@ploy-gyms/ai-specs": "workspace:*",
    "@ploy-gyms/shared-types": "workspace:*",
    "bullmq": "^5.41.7",
    "dotenv": "^16.4.7",
    "eventemitter2": "^6.4.9",
    "fastify": "^5.2.1",
    "fastify-cli": "^7.3.0",
    "fastify-plugin": "^5.0.1",
    "fastify-zod-openapi": "^4.1.1",
    "ioredis": "^5.6.0",
    "json-schema-to-ts": "^3.1.1",
    "kysely": "^0.27.6",
    "pg": "^8.13.3",
    "qs": "^6.14.0",
    "ts-pattern": "^5.6.2",
    "zod": "^3.24.2",
    "zod-openapi": "^4.2.3",
    "zod-validation-error": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^22.13.9",
    "@types/pg": "^8.11.11",
    "@types/qs": "^6.9.18",
    "@vitest/coverage-v8": "^3.0.8",
    "concurrently": "^9.1.2",
    "esbuild": "^0.25.0",
    "eslint": "^9.21.0",
    "fastify-tsconfig": "^3.0.0",
    "globals": "^16.0.0",
    "kysely-codegen": "^0.18.2",
    "kysely-ctl": "^0.12.1",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.26.0",
    "vitest": "^3.0.8"
  }
}
