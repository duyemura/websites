{
  "name": "@ploy-gyms/renderer",
  "version": "0.0.1",
  "private": true,
  "description": "Ploy for gyms — Astro site renderer",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "lint": "eslint .",
    "typecheck": "astro check",
    "use:fixture": "node -e \"require('fs').copyFileSync('src/content/gym.fixture.json','src/content/gym.json')\"",
    "use:fixture:beanburito": "node -e \"require('fs').copyFileSync('src/content/gym.beanburito.json','src/content/gym.json')\"",
    "test": "pnpm use:fixture && vitest run"
  },
  "dependencies": {
    "@astrojs/react": "^4.1.2",
    "@astrojs/tailwind": "^5.1.3",
    "@ploy-gyms/shared-types": "workspace:*",
    "astro": "^5.1.5",
    "marked": "^18.0.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@eslint/js": "^9.21.0",
    "@tailwindcss/typography": "^0.5.20",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "cheerio": "^1.2.0",
    "eslint": "^9.21.0",
    "globals": "^16.5.0",
    "tailwindcss": "3",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.26.0",
    "vitest": "^3.0.8"
  }
}
