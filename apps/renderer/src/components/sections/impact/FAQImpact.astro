---
import FAQSchema from "../../seo/FAQSchema.astro";
import type { FAQItem } from "../../../types/gym-content";
const { items, headline = "Questions? We have the answers." } = Astro.props as { items: FAQItem[]; headline?: string };
if (!items?.length) return;
---
<section class="bg-white py-16 lg:py-24">
  <div class="mx-auto max-w-3xl px-4 lg:px-6">
    <h2 class="mb-10 text-center font-heading text-3xl font-black uppercase leading-tight text-primary md:text-4xl">{headline}</h2>
    <div class="divide-y divide-slate-200">
      {items.map((f) => (
        <details class="faq-item py-5">
          <summary class="cursor-pointer font-heading text-lg font-bold text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent">
            {f.question}
          </summary>
          <p class="mt-3 leading-relaxed text-secondary">{f.answer}</p>
        </details>
      ))}
    </div>
  </div>
  <FAQSchema items={items} />
</section>
