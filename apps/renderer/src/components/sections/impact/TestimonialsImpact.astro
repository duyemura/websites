---
import type { Testimonial } from "../../../types/gym-content";
const NO_IMAGE = "__NO_IMAGE__";
const { headline = "What our members say", items } = Astro.props as { headline?: string; items: Testimonial[] };
if (!items?.length) return;
---
<section class="bg-primary py-16 lg:py-24 text-white">
  <div class="mx-auto max-w-7xl px-4 lg:px-6">
    <h2 class="mb-10 text-center font-heading text-3xl font-black uppercase leading-tight md:text-4xl">{headline}</h2>
    <div class="flex gap-5 overflow-x-auto pb-4 scrollbar-hide snap-x snap-mandatory">
      {items.map((t) => (
        <blockquote class="w-[85vw] flex-shrink-0 snap-start border border-white/10 bg-black p-6 sm:w-[45vw] lg:w-[30vw]">
          <p class="font-heading text-lg font-medium leading-relaxed">"{t.quote}"​</p>
          <footer class="mt-6 flex items-center gap-3">
            {t.photoUrl && t.photoUrl !== NO_IMAGE && (
              <img src={t.photoUrl} alt={t.name} width="40" height="40" class="h-10 w-10 rounded-full object-cover" />
            )}
            {(!t.photoUrl || t.photoUrl === NO_IMAGE) && <div class="h-10 w-10 rounded-full bg-white/20" />}
            <div>
              <cite class="not-italic text-sm font-semibold">{t.name}</cite>
              {t.program && <p class="text-xs uppercase tracking-wide text-slate-300">{t.program}</p>}
            </div>
          </footer>
        </blockquote>
      ))}
    </div>
  </div>
</section>
