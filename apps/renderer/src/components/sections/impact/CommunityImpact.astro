---
import type { ValueProp } from "../../../types/gym-content";
import Slant from "../../ui/Slant.astro";
const { items, headline } = Astro.props as { items: ValueProp[]; headline?: string };
if (!items?.length) return;
---
<section class="relative bg-primary py-16 lg:py-24 text-white">
  <div class="mx-auto max-w-7xl px-4 lg:px-6">
    <div class="grid gap-12 lg:grid-cols-2">
      <div>
        {headline && (
          <h2 class="max-w-[14ch] font-heading text-4xl font-black uppercase leading-[0.95] tracking-[-0.04em] md:text-5xl lg:text-6xl">
            {headline}
          </h2>
        )}
      </div>
      <div class="grid gap-x-10 gap-y-10 sm:grid-cols-2">
        {items.map((item) => (
          <div>
            <span class="mb-3 block text-3xl" aria-hidden="true">{item.icon}</span>
            <h3 class="font-heading text-lg font-bold uppercase tracking-wide">{item.headline}</h3>
            <p class="mt-2 text-sm leading-relaxed text-white/70">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
  <Slant direction="down" color="white" height={80} class="absolute bottom-0 left-0 right-0" />
</section>
