---
import type { HeroContent } from "../../../types/gym-content";
import { content } from "../../../lib/content";
const NO_IMAGE = "__NO_IMAGE__";
const { hero } = Astro.props as { hero: HeroContent };

let safeBgUrl = "";
if (hero.backgroundImageUrl && hero.backgroundImageUrl !== NO_IMAGE) {
  try {
    const u = new URL(hero.backgroundImageUrl, "https://x");
    if ((u.protocol === "http:" || u.protocol === "https:") && !u.hostname.includes("placehold.co")) {
      safeBgUrl = encodeURI(hero.backgroundImageUrl);
    }
  } catch { /* ignore */ }
}

const hasBg = !!safeBgUrl;
const bgStyle = hasBg
  ? `background-image:linear-gradient(to right,rgba(0,0,0,.85) 0%,rgba(0,0,0,.55) 60%,rgba(0,0,0,.35) 100%),url('${safeBgUrl}');background-size:cover;background-position:center;`
  : "";

const gymLabel = `Group training gym in ${content.business.geo.city}, ${content.business.geo.stateAbbr}`;
---
<section
  class:list={["relative flex min-h-[85vh] items-center", hasBg ? "bg-slate-900" : "bg-primary"]}
  style={bgStyle}
>
  <div class="mx-auto w-full max-w-7xl px-4 py-24 lg:px-6">
    <div class="max-w-2xl">
      <span class="inline-block bg-primary px-2 py-1 font-heading text-xs font-semibold uppercase tracking-wide text-white">
        {gymLabel}
      </span>
      <h1 data-testid="hero-headline" class="mt-4 font-heading text-4xl font-black uppercase leading-[0.95] text-white sm:text-5xl md:text-6xl lg:text-7xl">
        {hero.headline}
      </h1>
      {hero.subheading && (
        <p class="mt-6 max-w-lg text-lg leading-relaxed text-white/80">{hero.subheading}</p>
      )}
      {hero.ctaLabel && hero.ctaUrl && (
        <div class="mt-8">
          <a
            href={hero.ctaUrl}
            data-track="contact"
            class="group inline-flex items-center gap-3 bg-accent px-8 py-4 font-heading text-base font-bold uppercase tracking-wide text-white transition hover:bg-white hover:text-primary"
          >
            {hero.ctaLabel}
            <span aria-hidden="true" class="transition group-hover:translate-x-1">→</span>
          </a>
        </div>
      )}
    </div>
  </div>
</section>
