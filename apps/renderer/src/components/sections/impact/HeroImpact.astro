---
import type { HeroContent } from "../../../types/gym-content";
import { content } from "../../../lib/content";
import Slant from "../../ui/Slant.astro";
const NO_IMAGE = "__NO_IMAGE__";
const { hero } = Astro.props as { hero: HeroContent };

let safeBgUrl = "";
if (hero.backgroundImageUrl && hero.backgroundImageUrl !== NO_IMAGE) {
  try {
    const u = new URL(hero.backgroundImageUrl, "https://x");
    if ((u.protocol === "http:" || u.protocol === "https:") && !u.hostname.includes("placehold.co")) {
      safeBgUrl = encodeURI(hero.backgroundImageUrl);
    }
  } catch { /* ignore */ }
}

const hasBg = !!safeBgUrl;
const bgStyle = hasBg
  ? `background-image:linear-gradient(to bottom,rgba(0,0,0,.45) 0%,rgba(0,0,0,.65) 100%),url('${safeBgUrl}');background-size:cover;background-position:center;`
  : "";

const gymLabel = `Group training gym in ${content.business.geo.city}, ${content.business.geo.stateAbbr}`;
---
<section
  class:list={["relative flex min-h-[90vh] items-center", hasBg ? "bg-slate-900" : "bg-primary"]}
  style={bgStyle}
>
  <div class="mx-auto w-full max-w-7xl px-4 py-28 lg:px-6">
    <div class="max-w-3xl">
      <span class="inline-block bg-black px-2 py-1 font-heading text-xs font-semibold uppercase tracking-wide text-white">
        {gymLabel}
      </span>
      <h1
        data-testid="hero-headline"
        class="mt-5 font-heading text-5xl font-black uppercase leading-[0.92] tracking-[-0.04em] text-white sm:text-6xl md:text-7xl lg:text-8xl"
      >
        {hero.headline}
      </h1>
      {hero.subheading && (
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-white/90 md:text-xl">{hero.subheading}</p>
      )}
      {hero.ctaLabel && hero.ctaUrl && (
        <div class="mt-8">
          <a
            href={hero.ctaUrl}
            data-track="contact"
            class="group inline-flex items-center justify-between gap-6 bg-accent px-8 py-4 font-heading text-base font-black uppercase tracking-wide text-white transition hover:bg-white hover:text-primary md:text-lg"
          >
            <span>{hero.ctaLabel}</span>
            <span aria-hidden="true" class="text-xl transition-transform duration-200 group-hover:translate-x-1">→</span>
          </a>
        </div>
      )}
    </div>
  </div>
  <Slant direction="down" color="white" height={80} class="absolute bottom-0 left-0 right-0" />
</section>
