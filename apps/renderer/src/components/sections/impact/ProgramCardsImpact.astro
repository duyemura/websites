---
import { content, programBySlug } from "../../../lib/content";
const NO_IMAGE = "__NO_IMAGE__";
const { slugs, headline } = Astro.props as { slugs: string[]; headline?: string };
if (!slugs?.length) return;
const programs = slugs.map(programBySlug);
---
<section class="bg-primary py-16 lg:py-24">
  <div class="mx-auto max-w-7xl px-4 lg:px-6">
    {headline && <h2 class="mb-12 max-w-2xl font-heading text-3xl font-black uppercase leading-tight text-white md:text-4xl">{headline}</h2>}
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {programs.map((program) => {
        const hasCover = !!program.coverImageUrl && program.coverImageUrl !== NO_IMAGE && !program.coverImageUrl.includes("placehold.co");
        const bgStyle = hasCover
          ? `background-image:linear-gradient(to top,rgba(0,0,0,.9) 0%,rgba(0,0,0,.5) 50%,rgba(0,0,0,.3) 100%),url('${program.coverImageUrl}');background-size:cover;background-position:center;`
          : "";
        return (
          <a
            href={`/programs/${program.slug}`}
            class:list={[
              "group relative flex min-h-80 flex-col justify-end overflow-hidden p-6 transition-transform hover:-translate-y-1",
              hasCover ? "bg-slate-800" : "bg-gradient-to-t from-black via-slate-900 to-slate-800",
            ]}
            style={bgStyle}
          >
            <div class="relative z-10">
              <h3 class="font-heading text-2xl font-black uppercase leading-tight text-white md:text-3xl">{program.name}</h3>
              {program.shortDescription && <p class="mt-2 text-sm leading-relaxed text-white/70 line-clamp-2">{program.shortDescription}</p>}
              <span class="mt-4 inline-flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-white">
                Learn more
                <span aria-hidden="true" class="transition group-hover:translate-x-1">→</span>
              </span>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>
