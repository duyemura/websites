---
import { content, programBySlug } from "../../../lib/content";
const NO_IMAGE = "__NO_IMAGE__";
const { slugs, headline } = Astro.props as { slugs: string[]; headline?: string };
if (!slugs?.length) return;
const programs = slugs.map(programBySlug);
const { business } = content;
---
<section class="relative bg-primary py-16 lg:py-24">
  <div class="mx-auto max-w-7xl px-4 lg:px-6">
    <div class="grid gap-10 lg:grid-cols-12">
      <!-- Sticky left headline panel -->
      <div class="lg:col-span-5">
        <div class="lg:sticky lg:top-32">
          {headline && (
            <div>
              <h2 class="max-w-[16ch] font-heading text-4xl font-black uppercase leading-[0.95] tracking-[-0.04em] text-white md:text-5xl lg:text-6xl">
                {headline}
              </h2>
              <p class="mt-4 max-w-xs text-lg leading-relaxed text-white/80">Find a fitness routine that works for you.</p>
            </div>
          )}
          <a
            href={business.primaryCta.url}
            data-track="contact"
            class="mt-8 inline-flex items-center gap-4 bg-accent px-7 py-3.5 font-heading text-sm font-black uppercase tracking-wide text-white transition hover:bg-white hover:text-primary"
          >
            {business.primaryCta.label}
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>

      <!-- Program cards on the right -->
      <div class="flex flex-col gap-8 lg:col-span-7">
        {programs.map((program) => {
          const hasCover = !!program.coverImageUrl && program.coverImageUrl !== NO_IMAGE && !program.coverImageUrl.includes("placehold.co");
          const bgStyle = hasCover
            ? `background-image:linear-gradient(to top,rgba(0,0,0,.85) 0%,rgba(0,0,0,.35) 60%,rgba(0,0,0,.15) 100%),url('${program.coverImageUrl}');background-size:cover;background-position:center;`
            : "";
          return (
            <a
              href={`/programs/${program.slug}`}
              class:list={[
                "group relative flex min-h-[28rem] flex-col justify-end overflow-hidden p-8 transition-transform duration-300 hover:-translate-y-1",
                hasCover ? "bg-slate-800" : "bg-gradient-to-t from-black via-slate-900 to-slate-800",
              ]}
              style={bgStyle}
            >
              <div class="relative z-10 max-w-md">
                <h3 class="font-heading text-3xl font-black uppercase leading-[0.95] tracking-[-0.03em] text-white md:text-4xl">
                  {program.name}
                </h3>
                {program.shortDescription && <p class="mt-3 text-base leading-relaxed text-white/80">{program.shortDescription}</p>}
                <span class="mt-5 inline-flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-white"
                >
                  Learn more
                  <span aria-hidden="true" class="transition-transform duration-200 group-hover:translate-x-1">→</span>
                </span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </div>
</section>
