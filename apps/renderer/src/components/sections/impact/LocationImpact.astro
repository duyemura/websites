---
import { content } from "../../../lib/content";
const { business } = content;
if (!business.mapEmbedUrl && !business.address?.street) return;
const mapsQuery = encodeURIComponent(`${business.name} ${business.address.street} ${business.address.city} ${business.geo.stateAbbr}`);
const directions = `https://www.google.com/maps/search/?api=1&query=${mapsQuery}`;
const areaCopy = business.serviceArea?.length
  ? `${business.name} is located in ${business.geo.city}, ${business.geo.state}, and serves members from nearby communities including ${business.serviceArea.join(", ")}.`
  : `${business.name} is located in ${business.geo.city}, ${business.geo.state}.`;
---
<section class="bg-white py-16 lg:py-24">
  <div class="mx-auto max-w-7xl px-4 lg:px-6">
    <div class="grid items-stretch gap-10 lg:grid-cols-2">
      <div class="flex flex-col justify-center">
        <span class="mb-2 inline-block max-w-max bg-accent px-2 py-1 font-heading text-xs font-semibold uppercase tracking-wide text-white">Find us</span>
        <h2 class="font-heading text-3xl font-black uppercase leading-tight text-primary md:text-4xl">
          Located in {business.geo.city}
        </h2>
        <p class="mt-4 leading-relaxed text-secondary">{areaCopy}</p>
        <address class="mt-4 not-italic font-heading text-lg font-bold uppercase text-primary">
          {business.address.street}, {business.address.city}, {business.geo.stateAbbr} {business.address.zip}
        </address>
        <p class="mt-2">
          <a href={`tel:${business.phone.replace(/[^0-9+]/g, "")}`} class="text-accent hover:underline">{business.phone}</a>
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a
            href={directions}
            rel="noopener noreferrer"
            target="_blank"
            class="inline-block border-2 border-primary px-6 py-3 font-heading text-sm font-bold uppercase tracking-wide text-primary transition hover:bg-primary hover:text-white"
          >
            Get directions →
          </a>
          <a
            href="/contact"
            class="inline-block bg-primary px-6 py-3 font-heading text-sm font-bold uppercase tracking-wide text-white transition hover:bg-accent"
          >
            Contact us
          </a>
        </div>
      </div>
      {business.mapEmbedUrl && (
        <iframe
          src={business.mapEmbedUrl}
          title={`Map to ${business.name}`}
          width="600"
          height="400"
          loading="lazy"
          class="h-80 w-full border-0 lg:h-auto"
          referrerpolicy="no-referrer-when-downgrade"
          sandbox="allow-scripts allow-same-origin allow-popups allow-forms"
        ></iframe>
      )}
    </div>
  </div>
</section>
