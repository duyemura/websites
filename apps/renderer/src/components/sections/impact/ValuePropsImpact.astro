---
import type { ValueProp } from "../../../types/gym-content";
const { items } = Astro.props as { items: ValueProp[] };
if (!items?.length) return;
---
<section class="bg-white py-16 lg:py-24">
  <div class="mx-auto max-w-7xl px-4 lg:px-6">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
      {items.map((item) => (
        <div class="flex flex-col">
          <span class="mb-4 text-4xl" aria-hidden="true">{item.icon}</span>
          <h3 class="font-heading text-2xl font-black uppercase tracking-tight text-primary">{item.headline}</h3>
          <p class="mt-3 text-base leading-relaxed text-secondary">{item.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
