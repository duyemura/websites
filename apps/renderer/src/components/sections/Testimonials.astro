---
import type { Testimonial } from "../../types/gym-content";
import { NO_IMAGE } from "@ploy-gyms/shared-types/template-baseline";
const { headline, items } = Astro.props as { headline?: string; items: Testimonial[] };
if (!items?.length) return;
---
<section class="bg-slate-900 py-20">
  <div class="mx-auto max-w-6xl px-6">
    {headline && <h2 class="mb-12 text-center font-heading text-4xl font-black uppercase text-white">{headline}</h2>}
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {items.map((t) => (
        <div class="rounded-lg bg-slate-800 p-8">
          <p class="font-heading text-lg font-medium leading-relaxed text-white">"{t.quote}"</p>
          <div class="mt-6 flex items-center gap-3">
            {t.photoUrl && t.photoUrl !== NO_IMAGE && <img src={t.photoUrl} alt={t.name} width="40" height="40" class="h-10 w-10 rounded-full object-cover" />}
            {!t.photoUrl && <div class="h-10 w-10 rounded-full bg-muted" />}
            <div>
              <p class="font-semibold text-white text-sm">{t.name}</p>
              {t.program && <p class="text-xs text-accent uppercase tracking-wide">{t.program}</p>}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
