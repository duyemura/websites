---
import { content, programBySlug } from "../../lib/content";
import { NO_IMAGE } from "@ploy-gyms/shared-types/template-baseline";
const { slugs, headline } = Astro.props as { slugs: string[]; headline: string };
if (!slugs?.length) return;
const programs = slugs.map(programBySlug);
---
<section class="bg-slate-900 py-20">
  <div class="mx-auto max-w-6xl px-6">
    {headline && <h2 class="mb-12 font-heading text-4xl font-black uppercase text-white">{headline}</h2>}
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {programs.map((program) => {
        const hasCover = !!program.coverImageUrl && program.coverImageUrl !== NO_IMAGE && !program.coverImageUrl.includes("placehold.co");
        const bgStyle = hasCover
          ? `background-image:linear-gradient(rgba(0,0,0,.55),rgba(0,0,0,.75)),url('${program.coverImageUrl}');background-size:cover;background-position:center;`
          : "";
        return (
          <a
            href={`/programs/${program.slug}`}
            class:list={[
              "group relative flex min-h-64 flex-col justify-end p-6 transition-transform hover:-translate-y-1",
              hasCover ? "bg-slate-800" : "bg-gradient-to-br from-primary to-slate-800"
            ]}
            style={bgStyle}
          >
            <h3 class="font-heading text-2xl font-black uppercase text-white">{program.name}</h3>
            {program.shortDescription && (
              <p class="mt-1 text-sm text-slate-300 line-clamp-2">{program.shortDescription}</p>
            )}
            <span class="mt-4 text-xs font-semibold uppercase tracking-wider text-white group-hover:underline">
              Learn more →
            </span>
          </a>
        );
      })}
    </div>
  </div>
</section>
