---
import Container from "../ui/Container.astro";
import SectionHeading from "../ui/SectionHeading.astro";
const NO_IMAGE = "__NO_IMAGE__";
import type { TeamMember } from "../../types/gym-content";
const { team, variant = "light" } = Astro.props as { team: TeamMember[]; variant?: "light" | "dark" };

const isDark = variant === "dark";
const sectionBg = isDark ? "bg-black" : "bg-white";
const textColor = isDark ? "text-white" : "text-black";
const mutedText = isDark ? "text-white/70" : "text-black/70";
const avatarBg = isDark ? "bg-white" : "bg-primary";
const avatarFg = isDark ? "text-primary" : "text-secondary";
---
<section class={`py-16 ${sectionBg}`}>
  <Container>
    <SectionHeading
      title="Our coaching team"
      subtitle="Meet the coaches who guide every workout, answer your questions, and help you reach your goals."
      variant={isDark ? "dark" : "light"}
    />
    <div class="grid grid-cols-2 gap-8 sm:grid-cols-3 lg:grid-cols-4">
      {team.map((m) => (
        <div class="text-center">
          {m.photoUrl && m.photoUrl !== NO_IMAGE ? (
            <img src={m.photoUrl} alt={m.name} width="400" height="400" loading="lazy" class="aspect-square w-full rounded-xl object-cover" />
          ) : (
            <svg
              viewBox="0 0 100 100"
              aria-hidden="true"
              class={`aspect-square w-full rounded-xl p-6 ${avatarBg} ${avatarFg}`}
              preserveAspectRatio="xMidYMid meet"
            >
              <circle cx="50" cy="36" r="17" fill="currentColor" />
              <path
                d="M18 88c0-18 14-32 32-32h32c18 0 32 14 32 32v12H18V88z"
                fill="currentColor"
              />
            </svg>
          )}
          <h3 class={`mt-3 font-heading font-semibold ${textColor}`}>{m.name}</h3>
          <p class={`text-sm ${mutedText}`}>{m.title}</p>
          {m.bio && <p class={`mt-1 text-sm ${mutedText}`}>{m.bio}</p>}
        </div>
      ))}
    </div>
  </Container>
</section>
