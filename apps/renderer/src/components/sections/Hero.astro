---
import type { HeroContent } from "../../types/gym-content";
const { hero, h1 = true } = Astro.props as { hero: HeroContent; h1?: boolean };
const Tag = h1 ? "h1" : "h2";

let safeBgUrl = "";
if (hero.backgroundImageUrl) {
  try {
    const u = new URL(hero.backgroundImageUrl, "https://x");
    if ((u.protocol === "http:" || u.protocol === "https:") && !u.hostname.includes("placehold.co")) {
      safeBgUrl = encodeURI(hero.backgroundImageUrl);
    }
  } catch { /* ignore */ }
}

const hasBg = !!safeBgUrl;
const bgStyle = hasBg
  ? `background-image:linear-gradient(to right,rgba(0,0,0,.85) 0%,rgba(0,0,0,.6) 60%,rgba(0,0,0,.2) 100%),url('${safeBgUrl}');background-size:cover;background-position:center;`
  : "";
---
<section
  class:list={["relative flex min-h-[90vh] items-center", hasBg ? "bg-slate-900" : "bg-primary"]}
  style={bgStyle}
>
  <div class="mx-auto w-full max-w-6xl px-6 py-24">
    <div class="max-w-2xl">
      <Tag data-testid="hero-headline" class="font-heading text-5xl font-black uppercase leading-none text-white sm:text-6xl lg:text-8xl">
        {hero.headline}
      </Tag>
      {hero.subheading && hero.subheading.length < 120 && (
        <p class="mt-4 text-lg text-slate-200 max-w-xl">{hero.subheading}</p>
      )}
      {hero.ctaLabel && hero.ctaUrl && (
        <div class="mt-10">
          <a
            href={hero.ctaUrl}
            data-track="contact"
            class="inline-block bg-white px-8 py-4 font-heading text-base font-black uppercase tracking-wider text-primary transition hover:bg-slate-100"
          >
            {hero.ctaLabel}
          </a>
        </div>
      )}
    </div>
  </div>
</section>
