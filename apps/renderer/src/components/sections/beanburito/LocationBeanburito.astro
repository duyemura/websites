---
import { content } from "../../../lib/content";
const { business } = content;
const addressText = `${business.address.street} ${business.address.city}, ${business.geo.stateAbbr} ${business.address.zip}`;
const mapSearch = encodeURIComponent(`${business.address.street}, ${business.address.city}, ${business.geo.stateAbbr} ${business.address.zip}`);
---
<section class="section-skew-reverse section-overlap bg-white py-16 text-black lg:py-24">
  <div class="section-skew-inner-reverse mx-auto max-w-[90rem] px-6 lg:px-10">
    <div class="grid gap-10 lg:grid-cols-2">
      <div class="space-y-6">
        <span class="inline-block bg-accent px-3 py-1 font-heading text-xs font-bold uppercase tracking-wide text-white">
          {business.geo.city}
        </span>
        <h2 class="font-heading text-3xl font-black uppercase tracking-tight md:text-4xl lg:text-5xl">
          Select one of our locations
        </h2>
        <address class="not-italic text-lg leading-relaxed text-black/80">
          {addressText}
        </address>
        <a
          href={`https://www.google.com/maps/search/?api=1&query=${mapSearch}`}
          rel="noopener noreferrer"
          target="_blank"
          class="inline-flex items-center gap-2 text-sm font-bold uppercase tracking-wide text-accent hover:text-black"
        >
          Get directions
          <svg width="8" height="12" viewBox="0 0 8 12" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M1 1l5 5-5 5" />
          </svg>
        </a>

        {business.serviceArea && business.serviceArea.length > 0 && (
          <div class="pt-4">
            <p class="text-sm font-bold uppercase tracking-wide text-black/60">Areas served</p>
            <p class="mt-1 text-black/80">{business.serviceArea.join(", ")}</p>
          </div>
        )}
      </div>

      <div class="min-h-[300px] bg-black/10">
        {business.mapEmbedUrl ? (
          <iframe
            src={business.mapEmbedUrl}
            width="100%"
            height="100%"
            style="min-height: 300px; border: 0;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title={`Map showing ${business.name}`}
          />
        ) : (
          <div class="flex h-full min-h-[300px] items-center justify-center text-black/50">Map unavailable</div>
        )}
      </div>
    </div>
  </div>
</section>
