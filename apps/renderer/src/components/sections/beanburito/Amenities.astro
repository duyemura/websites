---
import type { Feature } from "../../../types/gym-content";
import IconCardGrid from "../IconCardGrid.astro";

const { items, headline, sectionId = "amenities" } = Astro.props as {
  items: Feature[];
  headline?: string;
  sectionId?: string;
};
if (!items?.length) return;
---

<IconCardGrid
  items={items.slice(0, 6)}
  variant="amenities"
  sectionId={sectionId}
  sectionTag="feature-grid"
  headline={headline}
  arrows
/>
