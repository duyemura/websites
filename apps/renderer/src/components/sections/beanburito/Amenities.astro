---
import type { Feature } from "../../../types/gym-content";
import { resolveIcon, iconHtml } from "../../../lib/beanburito-icons";
const NO_IMAGE = "__NO_IMAGE__";
const { items, headline } = Astro.props as { items: Feature[]; headline?: string };
if (!items?.length) return;

function hasImage(f: Feature): boolean {
  return !!f.imageUrl && f.imageUrl !== NO_IMAGE;
}
---
<section data-section="amenities" data-section-tag="feature-grid" class="section-straight bg-black py-20 text-white lg:py-28">
  <div class="mx-auto max-w-[90rem] px-6 lg:px-10">
    {headline && <h2 class="mx-auto mb-14 max-w-4xl text-center font-heading text-3xl font-black uppercase tracking-tight text-white md:text-4xl lg:text-5xl">{headline}</h2>}

    <div class="grid grid-cols-1 gap-0 md:grid-cols-2 lg:grid-cols-3">
      {items.slice(0, 6).map((f) => {
        const icon = resolveIcon(f.label, f.icon);
        const image = hasImage(f) ? `background-image: url('${f.imageUrl}');` : "";
        return (
          <div class="amenity-card group">
            {image && <div class="amenity-card-bg" style={image} />}
            <div class="amenity-card-overlay" />
            <div class="amenity-card-content">
              <span aria-hidden="true" class="mb-4 inline-block text-white" set:html={iconHtml(icon, 56)} />
              <h3 class="font-heading text-lg font-black uppercase tracking-tight text-white md:text-xl">{f.label}</h3>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
