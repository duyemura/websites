---
import { content, programBySlug } from "../../../lib/content";
import type { ProgramContent } from "../../../types/gym-content";
const NO_IMAGE = "__NO_IMAGE__";
const { slugs, headline } = Astro.props as { slugs: string[]; headline?: string };
if (!slugs?.length) return;
const programs = slugs.map(programBySlug);
const { business } = content;
---
<section class="section-skew-reverse section-overlap bg-black py-16 text-white lg:py-24">
  <div class="section-skew-inner-reverse mx-auto max-w-[90rem] px-6 lg:px-10">
    <div class="programs-layout flex flex-col gap-12 lg:flex-row lg:gap-20">
      <article class="st-programs lg:sticky lg:top-32 lg:w-[19rem] lg:flex-shrink-0 lg:self-start">
        {headline && (
          <h2 class="font-heading text-4xl font-black uppercase leading-[0.95] tracking-tight text-white md:text-5xl">
            {headline}
          </h2>
        )}
        <a
          href={business.primaryCta.url}
          data-track="contact"
          class="mt-8 inline-flex items-center gap-4 bg-accent px-8 py-4 font-heading text-sm font-black uppercase tracking-wide text-white transition hover:bg-[#0040a5]"
        >
          {business.primaryCta.label}
          <svg width="8" height="12" viewBox="0 0 8 12" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M1 1l5 5-5 5" />
          </svg>
        </a>
      </article>

      <div class="flex flex-1 flex-col gap-8">
        {programs.map((program: ProgramContent) => {
          const hasCover = !!program.coverImageUrl && program.coverImageUrl !== NO_IMAGE;
          return (
            <a
              href={`/programs/${program.slug}`}
              class="group relative flex min-h-[24rem] flex-col justify-end overflow-hidden p-8 lg:min-h-[28rem]"
            >
              {hasCover && (
                <img
                  src={program.coverImageUrl}
                  alt=""
                  loading="lazy"
                  class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                />
              )}
              <div class="absolute inset-0 bg-gradient-to-t from-black via-black/60 to-transparent" />
              <div class="relative z-10 max-w-xl">
                <h3 class="font-heading text-3xl font-black uppercase leading-[0.95] tracking-tight text-white md:text-4xl">
                  {program.name}
                </h3>
                {program.shortDescription && <p class="mt-3 text-white/80">{program.shortDescription}</p>}
                <span class="mt-5 inline-flex items-center gap-2 text-sm font-bold uppercase tracking-wider text-white">
                  Start your free trial
                  <svg width="8" height="12" viewBox="0 0 8 12" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" class="transition-transform group-hover:translate-x-1">
                    <path d="M1 1l5 5-5 5" />
                  </svg>
                </span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </div>
</section>
