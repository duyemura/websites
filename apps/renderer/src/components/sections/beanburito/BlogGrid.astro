---
import type { BlogPost } from "../../../types/gym-content";
const { posts, headline } = Astro.props as { posts: BlogPost[]; headline?: string };
if (!posts?.length) return;
const fmtDate = (d: string) =>
  new Intl.DateTimeFormat("en-US", { month: "short", day: "numeric", year: "numeric" }).format(new Date(d));
---

<section data-section="blogGrid" data-section-tag="content-block" class="section-straight bg-black py-20 text-white lg:py-28">
  <div class="mx-auto max-w-[90rem] px-6 lg:px-10">
    {headline && (
      <h2 class="mb-12 text-center font-heading text-3xl font-black uppercase tracking-tight text-white md:text-4xl lg:text-5xl">
        {headline}
      </h2>
    )}
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {posts.map((post) => (
        <a href={`/blog/${post.slug}`} class="group block overflow-hidden bg-white/5 transition hover:bg-white/10">
          {post.coverImageUrl && (
            <div class="aspect-[16/10] overflow-hidden">
              <img
                src={post.coverImageUrl}
                alt={post.title}
                loading="lazy"
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
            </div>
          )}
          <div class="p-6">
            {post.category && <span class="text-xs font-bold uppercase tracking-wide text-accent">{post.category}</span>}
            <h3 class="mt-2 font-heading text-xl font-black uppercase leading-tight text-white">{post.title}</h3>
            {post.excerpt && <p class="mt-3 line-clamp-3 text-white/70">{post.excerpt}</p>}
            <p class="mt-4 text-sm text-white/50">{fmtDate(post.publishedAt)}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
