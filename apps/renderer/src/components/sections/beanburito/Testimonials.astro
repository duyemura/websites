---
import { content } from "../../../lib/content";
import type { Testimonial } from "../../../types/gym-content";
const { items, headline } = Astro.props as { items: Testimonial[]; headline?: string };
const { business } = content;
const hasItems = items?.length > 0;
if (!headline && !hasItems) return;
---
<section data-section="testimonials" data-section-tag="testimonial-band" class="section-skew bg-black text-white">
  <div class="section-inner mx-auto max-w-[90rem] px-6 lg:px-10">
    {headline && <h2 class="mb-12 text-center font-heading text-3xl font-black uppercase tracking-tight text-white md:text-4xl lg:text-5xl">{headline}</h2>}

    {hasItems ? (
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {items.map((t) => (
          <div class="border-l-4 border-accent bg-white/5 p-8 text-white">
            <blockquote class="text-lg font-medium leading-relaxed">“{t.quote}”</blockquote>
            <div class="mt-6 flex items-center gap-3">
              {t.photoUrl && <img src={t.photoUrl} alt={t.name} class="h-10 w-10 rounded-full object-cover" loading="lazy" />}
              <div>
                <p class="font-heading text-sm font-bold uppercase">{t.name}</p>
                {t.program && <p class="text-xs text-white/60">{t.program}</p>}
              </div>
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div class="text-center text-white/70">
        <p class="text-lg">Join the members who train at {business.name} and share your story.</p>
      </div>
    )}
  </div>
</section>
