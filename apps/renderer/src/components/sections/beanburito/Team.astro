---
import TeamGrid from "../TeamGrid.astro";
const { team, title = "Our coaching team", subtitle = "Meet the coaches who guide every workout, answer your questions, and help you reach your goals." } = Astro.props as {
  team: Array<{ name: string; title: string; photoUrl?: string; bio?: string }>;
  title?: string;
  subtitle?: string;
};
if (!team?.length) return;
---

<section data-section="team" data-section-tag="content-block" class="section-skew bg-black text-white">
  <div class="section-inner mx-auto max-w-[90rem] px-6 lg:px-10">
    <TeamGrid team={team} variant="dark" title={title} subtitle={subtitle} />
  </div>
</section>
