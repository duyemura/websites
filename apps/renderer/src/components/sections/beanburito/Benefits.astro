---
import type { ValueProp } from "../../../types/gym-content";
const { items, sectionId = "benefits" } = Astro.props as { items: ValueProp[]; sectionId?: string };
if (!items?.length) return;

const icons: Record<string, string> = {
  "Reach new heights": "flag-person",
  "Easy workout scheduling": "calendar-check",
  "Guidance tailored toward your fitness goals": "target-arrow",
};
---
<section data-section={sectionId} data-section-tag="feature-grid" class="section-skew section-overlap bg-white py-16 lg:py-24">
  <div class="section-skew-inner mx-auto max-w-[90rem] px-6 lg:px-10">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
      {items.map((item) => {
        const icon = icons[item.headline] ?? "star";
        return (
          <div class="text-center">
            <span class="mb-4 inline-block text-accent" aria-hidden="true">
              {icon === "flag-person" && <svg width="64" height="64" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 56V8"/><path d="M16 12h22l-6 10 6 10H16"/><circle cx="28" cy="44" r="8"/><path d="M20 44h16"/></svg>}
              {icon === "calendar-check" && <svg width="64" height="64" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="8" y="14" width="48" height="44" rx="4"/><path d="M8 26h48"/><path d="M20 8v8"/><path d="M44 8v8"/><path d="M26 38l4 4 8-10"/></svg>}
              {icon === "target-arrow" && <svg width="64" height="64" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="32" cy="32" r="22"/><circle cx="32" cy="32" r="14"/><circle cx="32" cy="32" r="6"/><path d="M48 16l-2 10-10 2"/></svg>}
              {icon === "star" && <svg width="64" height="64" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M32 8l8 18 18 2-14 12 4 18-16-10-16 10 4-18-14-12 18-2z"/></svg>}
            </span>
            <h3 class="font-heading text-xl font-black uppercase tracking-tight text-black md:text-2xl">
              {item.headline}
            </h3>
            <p class="mt-3 leading-relaxed text-black/70">{item.body}</p>
          </div>
        );
      })}
    </div>
  </div>
</section>
