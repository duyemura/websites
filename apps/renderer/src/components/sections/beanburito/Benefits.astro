---
import type { ValueProp } from "../../../types/gym-content";
import IconCardGrid from "../IconCardGrid.astro";

const { items, headline = "Why train with us", variant = "valueProps", sectionId = "benefits" } = Astro.props as {
  items: ValueProp[];
  headline?: string;
  variant?: "valueProps" | "amenities" | "benefits" | "generic";
  sectionId?: string;
};
if (!items?.length) return;
---

<IconCardGrid
  items={items}
  variant={variant}
  sectionId={sectionId}
  sectionTag="feature-grid"
  headline={headline}
/>
