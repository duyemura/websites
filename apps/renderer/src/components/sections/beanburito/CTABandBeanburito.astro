---
import { content } from "../../../lib/content";
const { business } = content;
const { headline, ctaLabel = business.primaryCta.label, ctaUrl = business.primaryCta.url } = Astro.props as { headline: string; ctaLabel?: string; ctaUrl?: string };
---
<section class="section-skew section-overlap overflow-hidden bg-accent py-16 text-center text-white lg:py-24">
  <div class="section-skew-inner mx-auto max-w-4xl px-6 lg:px-10">
    <h2 class="font-heading text-3xl font-black uppercase tracking-tight md:text-4xl lg:text-5xl">{headline}</h2>
    {ctaLabel && ctaUrl && (
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a
          href={ctaUrl}
          data-track="contact"
          class="inline-flex items-center gap-4 border-2 border-white bg-white px-8 py-4 font-heading text-sm font-black uppercase tracking-wide text-accent transition hover:bg-transparent hover:text-white"
        >
          {ctaLabel}
          <svg width="8" height="12" viewBox="0 0 8 12" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M1 1l5 5-5 5" />
          </svg>
        </a>
        <a
          href={ctaUrl}
          data-track="contact"
          class="inline-flex items-center gap-4 border-2 border-white px-8 py-4 font-heading text-sm font-black uppercase tracking-wide text-white transition hover:bg-white hover:text-accent"
        >
          {ctaLabel}
          <svg width="8" height="12" viewBox="0 0 8 12" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M1 1l5 5-5 5" />
          </svg>
        </a>
      </div>
    )}
  </div>
</section>
