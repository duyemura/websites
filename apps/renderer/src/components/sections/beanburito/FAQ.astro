---
import FAQSchema from "../../seo/FAQSchema.astro";
import { content } from "../../../lib/content";
import type { FAQItem } from "../../../types/gym-content";
const { items, headline = "Questions? We have the answers!" } = Astro.props as { items: FAQItem[]; headline?: string };
if (!items?.length) return;
const { business } = content;
---
<section data-section="faq" data-section-tag="faq-block" class="section-skew bg-white text-black">
  <div class="section-inner mx-auto max-w-3xl px-6 lg:px-10">
    <div class="mb-10 text-center">
      <h2 class="font-heading text-3xl font-black uppercase tracking-tight text-black md:text-4xl">{headline}</h2>
      <p class="mt-2 text-black/70">Still curious? Talk to us!</p>
      {business.phone && (
        <a href={`tel:${business.phone.replace(/[^0-9+]/g, "")}`} class="mt-1 inline-block text-lg font-bold text-accent">
          {business.phone}
        </a>
      )}
    </div>

    <div class="divide-y divide-black/10">
      {items.map((f) => (
        <details class="faq-item py-5">
          <summary class="flex cursor-pointer list-none items-center justify-between font-heading text-lg font-bold text-black focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent">
            <span>{f.question}</span>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" class="faq-chevron transition-transform duration-200">
              <path d="M4 6l4 4 4-4" />
            </svg>
          </summary>
          <p class="mt-3 leading-relaxed text-black/70">{f.answer}</p>
        </details>
      ))}
    </div>

    <div class="mt-10 text-center">
      <a href="/contact" class="inline-flex items-center gap-2 font-heading text-sm font-bold uppercase tracking-wide text-accent hover:text-black">
        Contact us
        <svg width="8" height="12" viewBox="0 0 8 12" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M1 1l5 5-5 5" />
        </svg>
      </a>
    </div>
  </div>
  <FAQSchema items={items} />
</section>
