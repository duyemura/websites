---
import type { HeroContent } from "../../../types/gym-content";
const NO_IMAGE = "__NO_IMAGE__";
const { hero, h1 = true } = Astro.props as { hero: HeroContent; h1?: boolean };
const renderAsH1 = hero.renderAsH1 ?? h1;
const HeadlineTag = renderAsH1 ? "h1" : "h2";

const hasDesktopImage = !!hero.backgroundImageUrl && hero.backgroundImageUrl !== NO_IMAGE;
const safeBgUrl = hero.backgroundImageUrl ?? "";
const mobileImageUrl = hasDesktopImage ? safeBgUrl.replace(/\.webp$/, "-mobile.webp") : "";
---
<section data-section="hero" data-section-tag="hero" class="relative min-h-[46rem] w-full overflow-hidden bg-black text-white lg:min-h-[52rem]">
  {hasDesktopImage && (
    <>
      <img
        src={safeBgUrl}
        alt=""
        loading="eager"
        class="absolute inset-0 hidden h-full w-full object-cover object-center lg:block"
      />
      <img
        src={mobileImageUrl}
        alt=""
        loading="eager"
        class="absolute inset-0 h-full w-full object-cover object-center lg:hidden"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-black via-black/80 to-black/40" />
      <div class="absolute inset-0 bg-gradient-to-b from-black/70 via-transparent to-transparent" />
    </>
  )}

  <div class="section-inner relative z-10 mx-auto flex h-full max-w-[90rem] flex-col justify-center px-8 pb-24 pt-36 sm:px-12 md:px-16 lg:px-20 lg:pb-28 lg:pt-44 xl:px-24">
    <article class="max-w-3xl lg:max-w-4xl">
      {hero.subheading && (
        <div class="mb-6">
          <span
            class="inline-block font-heading text-base font-bold uppercase tracking-wide text-white md:text-lg"
            style="text-shadow: 0 1px 3px rgba(0,0,0,.7)"
          >
            {hero.subheading}
          </span>
        </div>
      )}
      <HeadlineTag
        data-testid="hero-headline"
        class="font-heading text-4xl font-black uppercase leading-[0.95] tracking-[-0.03em] text-white sm:text-5xl md:text-6xl lg:text-7xl break-words text-balance lg:leading-[0.98]"
      >
        {hero.headline}
      </HeadlineTag>
      {hero.intro && (
        <p
          class="mt-8 max-w-xl text-lg leading-relaxed text-white/90"
          style="text-shadow: 0 1px 3px rgba(0,0,0,.7)"
        >{hero.intro}</p>
      )}
      {hero.ctaLabel && hero.ctaUrl && (
        <footer class="mt-10">
          <a
            href={hero.ctaUrl}
            data-track="contact"
            class="cta-skew group inline-flex items-center gap-4 border-2 border-[var(--color-accent)] bg-[var(--color-accent)] px-8 py-4 font-heading text-sm font-black uppercase tracking-wide text-white transition hover:bg-transparent hover:text-white"
          >
            <span>{hero.ctaLabel}</span>
            <svg width="12" height="18" viewBox="0 0 8 12" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" class="transition-transform group-hover:translate-x-1">
              <path d="M1 1l5 5-5 5" />
            </svg>
          </a>
        </footer>
      )}
    </article>
  </div>
</section>
