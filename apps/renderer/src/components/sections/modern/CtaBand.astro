---
import { content } from "../../../lib/content";

const { headline, subtext, ctaLabel, ctaUrl } = Astro.props as {
  headline?: string;
  subtext?: string;
  ctaLabel?: string;
  ctaUrl?: string;
};
const { business } = content;
---

<section data-section="ctaBand" data-section-tag="cta-band" class="cta-band-modern">
  <div class="cta-band-inner">
    <h2 class="cta-headline">{headline ?? `Your fitness journey doesn't have to feel long. Be a ${business.name} member today.`}</h2>
    {subtext && <p class="cta-subtext">{subtext}</p>}
    <a href={ctaUrl ?? business.primaryCta.url} class="cta-btn">
      {ctaLabel ?? business.primaryCta.label}
    </a>
  </div>
</section>

<style>
  .cta-band-modern {
    background: #111;
    padding: 80px 20px;
    text-align: center;
  }
  .cta-band-inner {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 24px;
    align-items: center;
  }
  .cta-headline {
    font-family: var(--modern-font-heading, 'Montserrat', sans-serif);
    font-size: 2rem;
    font-weight: 900;
    color: #fff;
    margin: 0;
    line-height: 1.1;
  }
  .cta-subtext {
    font-family: var(--modern-font-body, 'Barlow', sans-serif);
    font-size: 1rem;
    color: rgba(255,255,255,0.75);
    margin: 0;
  }
  .cta-btn {
    display: inline-block;
    padding: 16px 36px;
    background: var(--modern-accent, #0464fc);
    color: #fff;
    font-family: var(--modern-font-heading, 'Montserrat', sans-serif);
    font-size: 1rem;
    font-weight: 700;
    text-decoration: none;
    border-radius: 6px;
  }
  @media (min-width: 768px) {
    .cta-headline { font-size: 2.5rem; }
  }
</style>
