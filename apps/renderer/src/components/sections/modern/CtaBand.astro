---
// "Every Body Is Unique. Find Something That Works For YOU"
// Source: large centered CTA text band between feature cards and programs

export interface Props {
  headline?: string;
  ctaText?: string;
  ctaHref?: string;
}

const {
  headline = "Every Body Is Unique. Find Something That Works For You",
  ctaText,
  ctaHref = "/programs",
} = Astro.props;
---

<section data-eval-component="CtaBand" class="cta-band">
  <div class="cta-inner">
    <h2 class="cta-headline">{headline}</h2>
    {ctaText && ctaHref && (
      <a href={ctaHref} class="cta-btn">{ctaText}</a>
    )}
  </div>
</section>

<style>
  .cta-band {
    background-color: #f5f5f5;
    padding: 80px 20px;
    text-align: center;
  }
  .cta-inner {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
  }
  .cta-headline {
    font-family: var(--modern-font-heading, 'Montserrat', sans-serif);
    font-size: 2.5rem;
    font-weight: 900;
    color: #111;
    margin: 0;
    line-height: 1.1;
  }
  .cta-btn {
    display: inline-block;
    background-color: var(--modern-accent, #0464fc);
    color: #fff;
    font-family: var(--modern-font-heading, 'Montserrat', sans-serif);
    font-weight: 700;
    font-size: 1rem;
    padding: 14px 32px;
    border-radius: 6px;
    text-decoration: none;
  }
  @media (min-width: 1024px) {
    .cta-headline { font-size: 3.5rem; }
  }
</style>
