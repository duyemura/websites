---
import { content } from "../../../lib/content";

const { headline } = Astro.props as { headline?: string };
const team = content.business.team ?? [];
---

{team.length > 0 && (
<section data-section="team" data-section-tag="team" class="team-modern">
  <div class="team-inner">
    <h2 class="team-headline">{headline ?? "Meet the Team"}</h2>
    <div class="team-grid">
      {team.map((member) => (
        <div class="team-card">
          {member.photoUrl && (
            <div class="team-photo-wrap">
              <img src={member.photoUrl} alt={member.name ?? ""} class="team-photo" loading="lazy" />
            </div>
          )}
          <div class="team-info">
            {member.name && <h3 class="team-name">{member.name}</h3>}
            {member.role && <p class="team-role">{member.role}</p>}
            {member.bio  && <p class="team-bio">{member.bio}</p>}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
)}

<style>
.team-modern {
  padding: 5rem 1.5rem;
  background: #f8f8f8;
}
.team-inner {
  max-width: 1100px;
  margin: 0 auto;
}
.team-headline {
  font-family: var(--modern-font-heading, "Montserrat", sans-serif);
  font-size: clamp(1.75rem, 4vw, 2.75rem);
  font-weight: 800;
  color: var(--modern-color-heading, #1a1a1a);
  text-align: center;
  margin-bottom: 3rem;
}
.team-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 2rem;
}
.team-card {
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 2px 12px rgba(0,0,0,.06);
}
.team-photo-wrap {
  aspect-ratio: 1;
  overflow: hidden;
}
.team-photo {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.team-info {
  padding: 1.25rem;
}
.team-name {
  font-family: var(--modern-font-heading, "Montserrat", sans-serif);
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--modern-color-heading, #1a1a1a);
  margin: 0 0 .25rem;
}
.team-role {
  font-size: .875rem;
  font-weight: 600;
  color: var(--modern-color-accent, #0464fc);
  margin: 0 0 .75rem;
  text-transform: uppercase;
  letter-spacing: .04em;
}
.team-bio {
  font-size: .9rem;
  color: #555;
  line-height: 1.6;
  margin: 0;
}
</style>
