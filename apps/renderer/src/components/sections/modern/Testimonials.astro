---
import type { Testimonial } from "../../../types/gym-content";
import { content } from "../../../lib/content";

const { headline, items } = Astro.props as { headline?: string; items: Testimonial[] };
const { business } = content;
---

<section data-section="testimonials" data-section-tag="testimonial-band" class="testimonials-modern">
  <div class="testimonials-inner">
    <h2 class="testimonials-headline">
      {headline ?? `Trusted and Loved By Hundreds of ${business.geo.city} Residents`}
    </h2>
    <div class="testimonials-grid">
      {(items ?? []).map((t) => (
        <blockquote class="testimonial-card">
          <div class="testimonial-stars" aria-label="5 stars">★★★★★</div>
          <p class="testimonial-quote">"{t.quote}"</p>
          <footer class="testimonial-footer">
            <strong class="testimonial-name">{t.name}</strong>
            {t.program && <span class="testimonial-program"> · {t.program}</span>}
          </footer>
        </blockquote>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials-modern {
    background: #fff;
    padding: 80px 20px;
  }
  .testimonials-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 48px;
    align-items: center;
    text-align: center;
  }
  .testimonials-headline {
    font-family: var(--modern-font-heading, 'Montserrat', sans-serif);
    font-size: 2rem;
    font-weight: 900;
    color: #111;
    margin: 0;
    max-width: 800px;
  }
  .testimonials-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    width: 100%;
    text-align: left;
  }
  .testimonial-card {
    background: #f5f5f5;
    border-radius: 8px;
    padding: 28px 24px;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .testimonial-stars {
    color: var(--modern-accent, #0464fc);
    font-size: 1.1rem;
    letter-spacing: 2px;
  }
  .testimonial-quote {
    font-family: var(--modern-font-body, 'Barlow', sans-serif);
    font-size: 0.975rem;
    line-height: 1.7;
    color: #333;
    margin: 0;
    flex: 1;
  }
  .testimonial-footer {
    font-family: var(--modern-font-heading, 'Montserrat', sans-serif);
    font-size: 0.875rem;
  }
  .testimonial-name { color: #111; font-weight: 700; }
  .testimonial-program { color: #666; }
  @media (min-width: 768px) {
    .testimonials-grid { grid-template-columns: repeat(2, 1fr); }
    .testimonials-headline { font-size: 2.5rem; }
  }
  @media (min-width: 1024px) {
    .testimonials-grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>
