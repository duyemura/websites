---
// Items are Feature objects: { icon: string, label: string, imageUrl?: string }
export interface FeatureGridEvenProps {
  id?: string;
  headline?: string;
  items: Array<{
    icon?: string;
    label?: string;
    imageUrl?: string;
  }>;
}

const { id, items = [] } = Astro.props;
---

<section id={id} data-eval-component="FeatureGridEven">
  <div class="feature-grid-container">
    {items.map((item) => (
      <div class="feature-item">
        {item.imageUrl && <img src={item.imageUrl} alt={item.label ?? ""} class="feature-icon" />}
        {item.icon && !item.imageUrl && <span class="feature-icon-text">{item.icon}</span>}
        <h3 class="feature-headline">{item.label}</h3>
      </div>
    ))}
  </div>
</section>

<style>
  section {
    padding-top: 0px;
    padding-bottom: 0px;
    background-color: rgb(241, 241, 241);
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 270px; /* To ensure it matches boundingBox height even with minimal content */
  }

  .feature-grid-container {
    display: flex;
    flex-direction: column;
    gap: 30px; /* Spacing between items on mobile */
    padding: 30px 20px; /* Adjust padding as needed for mobile */
    width: 100%;
    max-width: 375px; /* Constrain width for mobile view */
    box-sizing: border-box;
  }

  .feature-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 10px;
  }

  .feature-icon {
    width: 48px; /* Example size, adjust as per design */
    height: 48px; /* Example size, adjust as per design */
    object-fit: contain;
  }

  .feature-headline {
    font-size: 18px; /* Example font size, adjust as per design */
    font-weight: 600;
    color: #333;
    margin: 0;
  }

  .feature-description {
    font-size: 14px; /* Example font size, adjust as per design */
    color: #555;
    line-height: 1.5;
    margin: 0;
  }

  @media (min-width: 1440px) {
    .feature-grid-container {
      flex-direction: row;
      justify-content: space-around;
      gap: 0; /* Items will be spaced out by justify-content */
      max-width: 1200px; /* Max width for desktop content */
      padding: 60px 0; /* Adjust padding for desktop */
      height: 270px;
    }

    .feature-item {
      flex: 1; /* Distribute space evenly */
      max-width: 300px; /* Max width for each item on desktop */
      gap: 15px;
    }

    .feature-icon {
      width: 60px; /* Larger icon on desktop */
      height: 60px; /* Larger icon on desktop */
    }

    .feature-headline {
      font-size: 20px; /* Larger headline on desktop */
    }

    .feature-description {
      font-size: 16px; /* Larger description on desktop */
    }
  }
</style>