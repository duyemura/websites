---
// Items are Feature objects: { icon: string, label: string, imageUrl?: string }
export interface FeatureGridEvenProps {
  id?: string;
  headline?: string;
  description?: string; // Added description prop
  items: Array<{
    icon?: string;
    label?: string;
    imageUrl?: string;
  }>;
}

const { id, headline, description, items = [] } = Astro.props;
---

<section id={id} data-eval-component="FeatureGridEven" class="feature-grid-even">
  <div class="content-wrapper">
    {headline && <h2 class="headline">{headline}</h2>}
    {description && <p class="description">{description}</p>}
    <div class="items-grid">
      {items.map((item) => (
        <div class="grid-item">
          {item.imageUrl && <img src={item.imageUrl} alt={item.label ?? ""} class="item-icon" />}
          {item.icon && !item.imageUrl && <span class="item-icon-text">{item.icon}</span>}
          <h3 class="item-title">{item.label}</h3>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .feature-grid-even {
    background-color: var(--color-primary, rgb(241, 241, 241));
    padding: 100px 20px;
    display: flex;
    justify-content: center;
  }

  .content-wrapper {
    max-width: 1200px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 48px; /* Adjusted vertical spacing between headline and cards */
  }

  .headline {
    font-family: var(--font-heading, 'Montserrat', sans-serif);
    font-size: 3.8rem; /* Larger for headline */
    font-weight: 800; /* Bolder for headline */
    line-height: 1.1;
    color: #111;
    margin: 0 0 24px 0;
  }

  .description {
    font-family: var(--font-body, 'Open Sans', sans-serif);
    font-size: 1.15rem;
    color: #444;
    margin: 0 0 60px 0;
    max-width: 800px;
    line-height: 1.6;
  }

  .items-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    width: 100%;
  }

  .grid-item {
    display: flex;
    flex-direction: column;
    align-items: flex-start; /* Left-aligned text inside cards */
    text-align: left; /* Left-aligned text inside cards */
    padding: 40px 30px;
    background-color: #ffffff; /* Card background-color: white */
    border-radius: 20px; /* More rounded */
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15); /* More pronounced box-shadow */
    gap: 16px;
  }

  .item-icon {
    width: 64px;
    height: 64px;
    object-fit: contain;
    border-radius: 16px;
  }

  .item-icon-text {
    font-size: 3rem;
    display: block;
    color: var(--color-accent, #0464fc);
  }

  .item-title {
    font-family: var(--font-heading, 'Montserrat', sans-serif);
    font-size: 1.4rem;
    font-weight: 700;
    color: #222;
    margin: 0;
    line-height: 1.3;
  }

  /* Example for a button style if it were present */
  .cta-button {
    background-color: #7C3AED; /* Button background-color: #7C3AED */
    color: white;
    padding: 14px 28px;
    border-radius: 30px; /* Button border-radius: more rounded */
    text-decoration: none;
    font-weight: 600;
    transition: background-color 0.3s ease;
  }

  .cta-button:hover {
    background-color: #6D28D9; /* Darker shade for hover */
  }

  @media (min-width: 768px) {
    .items-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 40px;
    }
    .headline {
      font-size: 4.5rem; /* Larger for headline */
    }
  }

  @media (min-width: 1024px) {
    .items-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1440px) {
    .content-wrapper {
      padding: 0 40px;
    }
    .headline {
      font-size: 5.2rem; /* Larger for headline */
    }
    .items-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 48px;
    }
    .grid-item {
      padding: 45px 35px;
      border-radius: 25px; /* More rounded */
    }
    .item-icon {
      width: 80px;
      height: 80px;
    }
    .item-title {
      font-size: 1.55rem;
    }
  }
</style>