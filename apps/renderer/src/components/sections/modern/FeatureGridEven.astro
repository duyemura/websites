---
// Items are Feature objects: { icon: string, label: string, imageUrl?: string }
export interface FeatureGridEvenProps {
  id?: string;
  headline?: string;
  items: Array<{
    icon?: string;
    label?: string;
    imageUrl?: string;
  }>;
}

const { id, headline, items = [] } = Astro.props;
---

<section id={id} data-eval-component="FeatureGridEven" class="feature-grid-even">
  <div class="content-wrapper">
    {headline && <h2 class="headline">{headline}</h2>}
    <div class="items-grid">
      {items.map((item) => (
        <div class="grid-item">
          {item.imageUrl && <img src={item.imageUrl} alt={item.label ?? ""} class="item-icon" />}
          {item.icon && !item.imageUrl && <span class="item-icon-text">{item.icon}</span>}
          <h3 class="item-title">{item.label}</h3>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .feature-grid-even {
    background-color: rgb(241, 241, 241);
    padding-top: 60px;
    padding-bottom: 80px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .content-wrapper {
    max-width: 1200px;
    width: 100%;
    padding: 0 40px; /* Adjusted padding-left and padding-right */
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .headline {
    font-size: 2.5rem;
    font-weight: 800;
    line-height: 1.1;
    color: #111111;
    text-align: center;
    margin: 0 0 40px;
  }

  .items-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem; /* Adjusted gap */
    width: 100%;
  }

  .grid-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center; /* Adjusted text-align */
    padding: 28px 20px;
    background-color: #ffffff;
    border-radius: 1rem; /* Adjusted border-radius */
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
  }

  .item-icon {
    width: 56px;
    height: 56px;
    margin-bottom: 16px;
    object-fit: contain;
    border-radius: 12px;
  }

  .item-icon-text {
    font-size: 3rem; /* Adjusted font-size */
    margin-bottom: 16px;
    display: block;
    font-weight: bold; /* Adjusted font-weight */
  }

  .item-title {
    font-size: 1.25rem; /* Adjusted font-size */
    font-weight: 700;
    line-height: 1.3;
    color: #111111;
    margin: 0;
  }

  @media (min-width: 768px) {
    .items-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
  }

  @media (min-width: 1440px) {
    .content-wrapper {
      padding: 0 80px;
    }

    .headline {
      font-size: 4rem;
      font-weight: 900;
      margin-bottom: 64px;
    }

    .items-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 48px;
    }

    .grid-item {
      padding: 36px 28px;
      border-radius: 1.5rem;
    }

    .item-icon {
      width: 72px;
      height: 72px;
    }

    .item-title {
      font-size: 1.35rem;
      font-weight: 800;
      text-align: center;
    }
  }
</style>