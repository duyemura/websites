---
import type { Step } from "../../../types/gym-content";

const { headline, steps } = Astro.props as { headline?: string; steps: Step[] };
---

<section data-section="howItWorks" data-section-tag="steps-band" class="how-it-works">
  <div class="how-inner">
    <h2 class="how-headline">{headline ?? "Getting Started Is Easy"}</h2>
    <div class="steps-grid">
      {(steps ?? []).map((step) => (
        <div class="step-item">
          <div class="step-number">
            <span>{step.number ?? "?"}</span>
          </div>
          <h3 class="step-title">{step.headline}</h3>
          <p class="step-body">{step.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .how-it-works {
    background: #f5f5f5;
    padding: 80px 20px;
    text-align: center;
  }
  .how-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 56px;
  }
  .how-headline {
    font-family: var(--modern-font-heading, 'Montserrat', sans-serif);
    font-size: 2rem;
    font-weight: 900;
    color: #111;
    margin: 0;
  }
  .steps-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }
  .step-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .step-number {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--modern-accent, #0464fc);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .step-number span {
    font-family: var(--modern-font-heading, 'Montserrat', sans-serif);
    font-size: 1.35rem;
    font-weight: 900;
    color: #fff;
  }
  .step-title {
    font-family: var(--modern-font-heading, 'Montserrat', sans-serif);
    font-size: 1.15rem;
    font-weight: 800;
    color: #111;
    margin: 0;
  }
  .step-body {
    font-family: var(--modern-font-body, 'Barlow', sans-serif);
    font-size: 0.95rem;
    line-height: 1.65;
    color: #555;
    margin: 0;
    max-width: 280px;
  }
  @media (min-width: 768px) {
    .steps-grid { grid-template-columns: repeat(3, 1fr); gap: 48px; }
    .how-headline { font-size: 2.5rem; }
  }
</style>
