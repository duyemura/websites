---
// Items are Feature objects: { icon: string, label: string, imageUrl?: string }
export interface FeatureGridEvenFeatureGridProps {
  headline?: string;
  items?: Array<{
    icon?: string;
    label?: string;
    imageUrl?: string;
  }>;
}

const { headline, items = [] } = Astro.props;
---

<section data-eval-component="FeatureGridEvenFeatureGrid" class="feature-grid-even-feature-grid">
  <div class="content-wrapper">
    {headline && <h2 class="headline">{headline}</h2>}
    <div class="feature-list">
      {items.map((item) => (
        <div class="feature-item">
          {item.imageUrl && <img src={item.imageUrl} alt={item.label ?? ""} class="feature-icon" />}
          {item.icon && !item.imageUrl && <span class="feature-icon-text">{item.icon}</span>}
          <h3 class="feature-title">{item.label}</h3>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .feature-grid-even-feature-grid {
    background-color: var(--color-primary, rgb(248, 248, 248)); /* Light gray/off-white background */
    padding-top: 60px;
    padding-bottom: 60px;
  }

  .content-wrapper {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 48px; /* More vertical space between section title and cards */
    padding: 0 20px;
  }

  .headline {
    font-family: var(--font-heading, 'Montserrat', sans-serif);
    font-size: 3rem; /* Larger font size for section title */
    font-weight: 800; /* Bolder font weight for section title */
    line-height: 1.1;
    color: var(--color-text, #333);
    margin: 0;
    text-align: center;
  }

  .feature-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  .feature-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
    background-color: white;
    border-radius: 16px; /* More rounded corners for cards */
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15); /* More prominent box-shadow for cards */
    padding: 40px; /* More padding around the content within the cards */
  }

  .feature-icon {
    width: 60px;
    height: 60px;
    object-fit: contain;
    border-radius: 10px;
  }

  .feature-icon-text {
    font-size: 3rem;
    display: block;
    color: var(--color-accent, #0464fc);
  }

  .feature-title {
    font-family: var(--font-heading, 'Montserrat', sans-serif);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-text, #333);
    margin: 0;
    line-height: 1.3;
  }

  .cta-button {
    background-color: var(--color-accent, #0464fc); /* CTA buttons should use var(--color-accent, #0464fc) */
    color: white;
    padding: 12px 24px;
    border-radius: 25px;
    text-decoration: none;
    font-weight: 600;
    display: inline-block;
    transition: background-color 0.3s ease;
  }

  .cta-button:hover {
    background-color: #034cb7; /* Slightly darker accent on hover */
  }

  @media (min-width: 768px) {
    .content-wrapper {
      gap: 60px; /* More vertical space */
    }
    .headline {
      font-size: 3.5rem; /* Larger font size for section title */
    }
    .feature-list {
      grid-template-columns: repeat(2, 1fr);
      gap: 30px;
    }
    .feature-item {
      padding: 45px; /* More padding */
    }
    .feature-icon {
      width: 70px;
      height: 70px;
    }
    .feature-icon-text {
      font-size: 3.5rem;
    }
    .feature-title {
      font-size: 1.4rem;
    }
  }

  @media (min-width: 1024px) {
    .content-wrapper {
      padding: 0;
    }
    .headline {
      font-size: 4rem; /* Larger font size for section title */
    }
    .feature-list {
      grid-template-columns: repeat(4, 1fr);
      gap: 40px;
    }
    .feature-item {
      padding: 50px; /* More padding */
    }
    .feature-icon {
      width: 80px;
      height: 80px;
    }
    .feature-icon-text {
      font-size: 4rem;
    }
    .feature-title {
      font-size: 1.5rem;
    }
  }
</style>