---
// Items are Feature objects: { icon: string, label: string, imageUrl?: string }
export interface FeatureGridEvenFeatureGridProps {
  headline?: string;
  items?: Array<{
    icon?: string;
    label?: string;
    imageUrl?: string;
  }>;
}

const { headline, items = [] } = Astro.props;
---

<section data-eval-component="FeatureGridEvenFeatureGrid" class="feature-grid-even-feature-grid">
  <div class="content-wrapper">
    <div class="text-content">
      {headline && <h2 class="headline">{headline}</h2>}
      <div class="feature-list">
        {items.map((item) => (
          <div class="feature-item">
            {item.imageUrl && <img src={item.imageUrl} alt={item.label ?? ""} class="feature-icon" />}
            {item.icon && !item.imageUrl && <span class="feature-icon-text">{item.icon}</span>}
            <div class="feature-details">
              <h3 class="feature-title">{item.label}</h3>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .feature-grid-even-feature-grid {
    padding-top: 0px;
    padding-bottom: 0px;
    background-color: #f7f7f7; /* Adjust as needed, based on image background */
  }

  .content-wrapper {
    display: flex;
    flex-direction: column;
    gap: 40px;
    margin: 0 auto;
    max-width: 1440px;
    padding: 60px 20px;
  }

  .text-content {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .headline {
    font-size: 32px;
    line-height: 1.2;
    font-weight: 700;
    color: #1a1a1a;
  }

  .subheadline {
    font-size: 16px;
    line-height: 1.5;
    color: #4a4a4a;
  }

  .feature-list {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .feature-item {
    display: flex;
    align-items: flex-start;
    gap: 15px;
  }

  .feature-icon {
    width: 48px;
    height: 48px;
    flex-shrink: 0;
  }

  .feature-details {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .feature-title {
    font-size: 20px;
    line-height: 1.3;
    font-weight: 600;
    color: #1a1a1a;
  }

  .feature-description {
    font-size: 16px;
    line-height: 1.5;
    color: #4a4a4a;
  }

  .image-content {
    width: 100%;
    overflow: hidden; /* Ensures image doesn't spill */
  }

  .main-image {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 8px; /* Example, adjust if needed */
  }

  @media (min-width: 1440px) {
    .content-wrapper {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      padding: 100px 80px;
      gap: 80px;
    }

    .text-content {
      flex: 1;
      max-width: 50%;
      gap: 32px;
    }

    .headline {
      font-size: 48px;
      line-height: 1.1;
    }

    .subheadline {
      font-size: 18px;
    }

    .feature-list {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 40px 60px;
    }

    .feature-item {
      width: calc(50% - 30px); /* Two columns */
      gap: 20px;
    }

    .feature-icon {
      width: 56px;
      height: 56px;
    }

    .feature-title {
      font-size: 24px;
    }

    .feature-description {
      font-size: 17px;
    }

    .image-content {
      flex: 1;
      max-width: 50%;
    }

    .main-image {
      height: 600px; /* Adjust height as needed for desktop */
      object-fit: cover;
    }
  }
</style>