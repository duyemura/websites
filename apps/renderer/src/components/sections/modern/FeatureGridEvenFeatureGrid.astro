---
// Items are Feature objects: { icon: string, label: string, imageUrl?: string }
export interface FeatureGridEvenFeatureGridProps {
  headline?: string;
  items?: Array<{ icon?: string; label?: string; imageUrl?: string; }>;
}
const { headline, items = [] } = Astro.props;
---

<section data-eval-component="FeatureGridEvenFeatureGrid" class="feature-grid-even-feature-grid">
  <div class="content-wrapper">
    {headline && <h2 class="headline">{headline}</h2>}
    <div class="cards">
      {items.map((item) => (
        <div class="card">
          {item.imageUrl && <img src={item.imageUrl} alt={item.label ?? ""} class="card-icon" />}
          {item.icon && !item.imageUrl && <span class="card-icon-emoji">{item.icon}</span>}
          <h3 class="card-title">{item.label}</h3>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .feature-grid-even-feature-grid {
    background-color: #f5f5f5;
    padding: 80px 20px;
  }
  .content-wrapper {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 48px;
    align-items: flex-start;
  }
  .headline {
    font-family: var(--modern-font-heading, 'Montserrat', sans-serif);
    font-size: 2.25rem;
    font-weight: 900;
    color: #111;
    margin: 0;
    line-height: 1.05;
  }
  .cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    width: 100%;
  }
  .card {
    background: #fff;
    border-radius: 12px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  }
  .card-icon { width: 48px; height: 48px; object-fit: contain; }
  .card-icon-emoji {
    font-size: 2rem;
    color: var(--modern-accent, #0464fc);
  }
  .card-title {
    font-family: var(--modern-font-heading, 'Montserrat', sans-serif);
    font-size: 1rem;
    font-weight: 700;
    color: #111;
    margin: 0;
  }
  @media (min-width: 640px) { .cards { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) {
    .cards { grid-template-columns: repeat(4, 1fr); gap: 32px; }
    .headline { font-size: 2.75rem; }
  }
</style>
