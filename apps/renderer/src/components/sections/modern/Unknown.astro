---
export interface Props {
  headline?: string;
  body?: string;
}
const { headline = "", body = "" } = Astro.props;
---

<section data-eval-component="Unknown" class="unknown-section">
  <div class="unknown-section__inner">
    {headline && <h2>{headline}</h2>}
    {body && <p>{body}</p>}
  </div>
</section>

<style>
.unknown-section {
  padding: 8rem 2rem;
  background-color: #111111;
  color: #ffffff;
  text-align: center;
}
.unknown-section__inner {
  max-width: 56rem;
  margin: 0 auto;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.unknown-section h2 {
  font-size: 3.5rem;
  font-weight: 900;
  margin: 0 0 2rem;
  color: #ffffff;
  line-height: 1.05;
  text-align: center;
}
.unknown-section p {
  font-size: 1.25rem;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.4;
  max-width: 42rem;
  margin: 0 auto;
  text-align: center;
}
</style>