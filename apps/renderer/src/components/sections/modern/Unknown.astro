---
export interface Props {
  title?: string;
  description?: string;
  cards: {
    icon: string;
    title: string;
    description: string;
  }[];
}

const {
  title = "Our Process",
  description = "Follow these simple steps to get started with our services. We've streamlined our process to ensure efficiency and clarity every step of the way.",
  cards = [
    {
      icon: "mdi:lightbulb-outline",
      title: "Discovery",
      description:
        "We start by understanding your needs, goals, and challenges through in-depth consultations.",
    },
    {
      icon: "mdi:pencil-ruler",
      title: "Planning",
      description:
        "Based on our discovery, we craft a tailored strategy and detailed plan of action.",
    },
    {
      icon: "mdi:code-tags",
      title: "Development",
      description:
        "Our team brings your vision to life with expert execution and attention to detail.",
    },
    {
      icon: "mdi:rocket-launch-outline",
      title: "Launch",
      description:
        "After rigorous testing, we deploy your solution and ensure a smooth rollout.",
    },
  ],
} = Astro.props;
---

<section data-eval-component="Unknown" class="py-16 md:py-24 bg-transparent text-gray-800">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-left mb-12 md:mb-16">
      <h2 class="text-4xl md:text-5xl font-extrabold leading-tight text-gray-900 mb-6">
        {title}
      </h2>
      <p class="text-lg md:text-xl text-gray-700 leading-relaxed max-w-3xl">
        {description}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-10">
      {
        cards.map((card) => (
          <div class="bg-[#E0F7FA] rounded-xl p-8 shadow-lg hover:shadow-xl transition-shadow duration-300">
            <div class="flex items-center mb-6">
              <h3 class="text-2xl font-bold text-gray-900">{card.title}</h3>
            </div>
            <p class="text-base text-gray-700 leading-relaxed">
              {card.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>

