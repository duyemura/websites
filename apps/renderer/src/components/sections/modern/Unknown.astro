---
export interface Props { headline?: string; body?: string; }
const { headline = "", body = "" } = Astro.props;
---

<section data-eval-component="Unknown" class="unknown-section">
  <div class="inner">
    {headline && <h2>{headline}</h2>}
    {body && <p>{body}</p>}
  </div>
</section>

<style>
  .unknown-section {
    background-color: #f5f5f5;
    padding: 80px 20px;
    text-align: center;
  }
  .inner {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: center;
  }
  h2 {
    font-family: var(--modern-font-heading, 'Montserrat', sans-serif);
    font-size: 2.25rem;
    font-weight: 900;
    color: #111;
    margin: 0;
    line-height: 1.1;
  }
  p {
    font-family: var(--modern-font-body, 'Barlow', sans-serif);
    font-size: 1.1rem;
    color: #555;
    margin: 0;
    max-width: 600px;
  }
</style>
