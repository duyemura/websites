---
export interface Props {
  headline?: string;
  subheadline?: string;
  ctaText?: string;
  ctaHref?: string;
  backgroundImageUrl?: string;
}
const { headline, subheadline, ctaText, ctaHref, backgroundImageUrl } = Astro.props;
const hasImage = !!backgroundImageUrl && backgroundImageUrl !== "__NO_IMAGE__";
---

<section
  data-eval-component="HeroCenter"
  class="hero-center"
  style={hasImage ? `background-image:url(${backgroundImageUrl});background-size:cover;background-position:center;` : ""}
>
  {hasImage && <div class="overlay" />}
  <div class="hero-content">
    {headline && <h1 class="headline">{headline}</h1>}
    {subheadline && <p class="subheadline">{subheadline}</p>}
    {ctaText && ctaHref && <a href={ctaHref} class="cta-btn">{ctaText}</a>}
  </div>
</section>

<style>
  .hero-center {
    position: relative;
    background-color: #f5f5f5;
    min-height: 560px;
    display: flex;
    align-items: flex-end;
    padding: 60px 40px;
  }
  .overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0.15) 60%);
    z-index: 1;
  }
  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 560px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .headline {
    font-family: var(--modern-font-heading, 'Montserrat', sans-serif);
    font-size: 3rem;
    font-weight: 900;
    line-height: 1.05;
    color: #111;
    margin: 0;
  }
  .subheadline {
    font-family: var(--modern-font-body, 'Barlow', sans-serif);
    font-size: 1.1rem;
    line-height: 1.6;
    color: #333;
    margin: 0;
  }
  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    background-color: var(--modern-accent, #0464fc);
    color: #fff;
    font-family: var(--modern-font-heading, 'Montserrat', sans-serif);
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    border-radius: 6px;
    align-self: flex-start;
  }
  /* when image is present, text goes white */
  .hero-center:has(.overlay) .headline,
  .hero-center:has(.overlay) .subheadline { color: #fff; }

  @media (min-width: 768px) {
    .hero-center { min-height: 640px; padding: 80px 60px; }
    .headline { font-size: 4rem; }
  }
  @media (min-width: 1440px) {
    .hero-center { min-height: 720px; padding: 100px 120px; }
    .headline { font-size: 4.5rem; }
    .hero-content { max-width: 640px; }
  }
</style>
