---
export interface Props {
  headline?: string;
  subheadline?: string;
  ctaText?: string;
  ctaHref?: string;
  // Spec provides backgroundImageUrl (from hero.backgroundImageUrl)
  backgroundImageUrl?: string;
}

const { headline, subheadline, ctaText, ctaHref, backgroundImageUrl } = Astro.props;
const hasImage = backgroundImageUrl && backgroundImageUrl !== "__NO_IMAGE__";
---

<section data-eval-component="HeroCenter" id="index-seg-1" class="hero-center" style={hasImage ? `background-image: url(${backgroundImageUrl}); background-size: cover; background-position: center;` : ""}>
  <div class="hero-content">
    {headline && <h1 class="headline">{headline}</h1>}
    {subheadline && <p class="subheadline">{subheadline}</p>}
    {ctaText && ctaHref && <a href={ctaHref} class="button">{ctaText}</a>}
  </div>
</section>

<style>
  .hero-center {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding-top: 0px;
    padding-bottom: 0px;
    background-color: rgb(241, 241, 241);
    font-family: sans-serif; /* Default font, adjust if specific font is provided in global CSS */
  }

  .hero-content {
    padding: 20px;
    max-width: 375px;
  }

  .headline {
    font-size: 36px;
    line-height: 1.2;
    margin-bottom: 16px;
    color: #333; /* Placeholder, adjust if specific color is provided */
  }

  .subheadline {
    font-size: 18px;
    line-height: 1.5;
    margin-bottom: 24px;
    color: #555; /* Placeholder, adjust if specific color is provided */
  }

  .button {
    display: inline-block;
    padding: 12px 24px;
    background-color: #007bff; /* Example color, adjust if specific color is provided */
    color: white;
    text-decoration: none;
    border-radius: 5px;
    font-weight: bold;
    transition: background-color 0.3s ease;
  }

  .button:hover {
    background-color: #0056b3; /* Example hover color */
  }

  @media (min-width: 1440px) {
    .hero-center {
      flex-direction: column;
      justify-content: center;
      padding-top: 0px;
      padding-bottom: 0px;
      height: auto;
    }

    .hero-content {
      max-width: 800px;
      padding: 60px 40px;
    }

    .headline {
      font-size: 64px;
      margin-bottom: 24px;
    }

    .subheadline {
      font-size: 22px;
      margin-bottom: 32px;
    }

    .button {
      padding: 16px 32px;
      font-size: 20px;
    }
  }
</style>