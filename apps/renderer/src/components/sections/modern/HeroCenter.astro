[data-eval-component="HeroCenter"] h3{ margin-top: 0px; margin-bottom: 0px; font-size: 38px; font-style: italic; font-weight: 900; line-height: 130%; }
[data-eval-component="HeroCenter"] .hero-card{ background-color: var(--white-text-colour); border-radius: 10px; max-width: 350px; padding: 40px 40px 60px; box-shadow: rgba(0, 0, 0, 0.05) 0px 20px 120px; }
[data-eval-component="HeroCenter"] .hero-card-title{ letter-spacing: -2%; margin-top: 40px; margin-bottom: 16px; font-family: Montserrat, sans-serif; font-size: 28px; font-style: normal; font-weight: 700; line-height: 125%; }
[data-eval-component="HeroCenter"] .hero-card-subtext{ color: var(--text-colour); font-family: Montserrat, sans-serif; font-size: 15px; font-weight: 500; line-height: 150%; }
@media screen and (max-width: 479px) {
[data-eval-component="HeroCenter"] .hero-card { width: 100%; max-width: none; padding: 30px 30px 40px; }[data-eval-component="HeroCenter"] .hero-card-title { margin-top: 10px; font-size: 24px; } 
}
@font-face { font-family: FontAwesome; src: url("../fonts/fontawesome-webfont.woff2?v=4.5.0") format("woff2"), url("../fonts/fontawesome-webfont.woff?v=4.5.0") format("woff"), url("../fonts/fontawesome-webfont.ttf?v=4.5.0") format("truetype"); font-weight: normal; font-style: normal; }
@-webkit-keyframes fa-spin { 
  0% { transform: rotate(0deg); }
  100% { transform: rotate(359deg); }
}
@keyframes fa-spin { 
  0% { transform: rotate(0deg); }
  100% { transform: rotate(359deg); }
}
@keyframes vdpSlideFromLeft { 
  0% { opacity: 0; transform: translate3d(-0.5em, 0px, 0px); }
  100% { opacity: 1; transform: translateZ(0px); }
}
@keyframes vdpSlideFromRight { 
  0% { opacity: 0; transform: translate3d(0.5em, 0px, 0px); }
  100% { opacity: 1; transform: translateZ(0px); }
}
@keyframes vdpToggleCalendar { 
  0% { opacity: 0; transform: scale(0.5); }
  100% { opacity: 1; transform: scale(1); }
}
@keyframes vdpFadeCalendar { 
  0% { opacity: 0; }
  100% { opacity: 1; }
}
@keyframes rotateSlideOutNext { 
  0% { position: absolute; }
  25% { opacity: 0.5; transform: translateZ(-500px); }
  75%, 100% { opacity: 0.5; transform: translateZ(-500px) translate(-200%); }
}
@keyframes rotateSlideInNext { 
  0%, 25% { opacity: 0.5; position: relative; transform: translateZ(-500px) translate(200%); }
  75% { opacity: 0.5; transform: translateZ(-500px); }
  100% { opacity: 1; transform: translateZ(0px) translate(0px); }
}
@keyframes rotateSlideOutPrev { 
  0% { position: absolute; }
  25% { opacity: 0.5; transform: translateZ(-500px); }
  75%, 100% { opacity: 0.5; transform: translateZ(-500px) translate(200%); }
}
@keyframes rotateSlideInPrev { 
  0%, 25% { opacity: 0.5; position: relative; transform: translateZ(-500px) translate(-200%); }
  75% { opacity: 0.5; transform: translateZ(-500px); }
  100% { opacity: 1; transform: translateZ(0px) translate(0px); }
}
@keyframes v-moonStretchDelay { 
  100% { transform: rotate(1turn); }
}
@keyframes spin { 
  0% { transform: rotate(0deg); }
  100% { transform: rotate(1turn); }
}
[data-eval-component="HeroCenter"] *,
[data-eval-component="HeroCenter"] ::after,
[data-eval-component="HeroCenter"] ::before{ box-sizing: inherit; }
@keyframes rotate-spinner { 
  0% { transform: rotate(0deg); }
  100% { transform: rotate(1turn); }
}
@keyframes cvc-indicate-location { 
  0% { opacity: 1; }
  100% { opacity: 0.3; }
}
@keyframes card-bounce { 
  0% { animation-timing-function: cubic-bezier(0.17, 0.17, 0.32, 1); translate: 0px -60%; }
  9.70874% { animation-timing-function: cubic-bezier(0.41, 0, 0.49, 1); translate: 0px 8.5%; }
  23.4466% { animation-timing-function: cubic-bezier(0.29, 0, 0.26, 1); translate: 0px -22.5%; }
  47.7184% { translate: 0px; }
  63.8835% { animation-timing-function: cubic-bezier(1, 0, 0.78, 1); translate: 0px; }
  86.5534% { translate: 0px 40.7%; }
  100% { translate: 0px 40.7%; }
}
@keyframes card-fade-100 { 
  0% { animation-timing-function: linear; opacity: 0; }
  8.1068% { opacity: 1; }
  78.4466% { opacity: 1; }
  86.5534% { opacity: 0; }
  100% { opacity: 0; }
}
@keyframes card-fade-60 { 
  0% { animation-timing-function: linear; opacity: 0; }
  8.1068% { opacity: 0.6; }
  78.4466% { opacity: 0.6; }
  86.5534% { opacity: 0; }
  100% { opacity: 0; }
}
@keyframes card-fade-20 { 
  0% { animation-timing-function: linear; opacity: 0; }
  8.1068% { opacity: 0.2; }
  78.4466% { opacity: 0.2; }
  86.5534% { opacity: 0; }
  100% { opacity: 0; }
}
@keyframes v-moonStretchDelay-66d6a623 { 
  100% { transform: rotate(1turn); }
}
@keyframes modalSlideIn-ce9c2e24 { 
  0% { opacity: 0; transform: translateY(-20px) scale(0.95); }
  100% { opacity: 1; transform: translateY(0px) scale(1); }
}
@keyframes spinning { 
  0% { transform: rotate(0deg); }
  100% { transform: rotate(2turn); }
}
@keyframes skeleton-loading-a620868e { 
  0% { background-position: 100% 50%; }
  100% { background-position: 0px 50%; }
}
[data-eval-component="HeroCenter"] *,
[data-eval-component="HeroCenter"] ::before,
[data-eval-component="HeroCenter"] ::after{ animation-duration: 0s !important; transition-duration: 0s !important; }
