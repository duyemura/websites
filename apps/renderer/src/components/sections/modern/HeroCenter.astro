---
// Default images from the Beta Gym modern template source site.
// Gyms replace these with their own photos via GymSiteContent.pages.home.hero.backgroundImageUrl
const CDN = "https://cdn.prod.website-files.com/63caaac34d6a3583a0074c0d";
const DEFAULT_HERO_DESKTOP = `${CDN}/64086ce7b78d3f0900fdd620_Untitled%20design%20(2).png`;
const DEFAULT_HERO_MOBILE  = `${CDN}/63ce2e8f2960e9a122454347_Homepage%20at%20Beta%20Gym%20Modern%20in%20Manhattan.jpg`;

export interface Props {
  headline?: string;
  subheadline?: string;
  ctaText?: string;
  ctaHref?: string;
  backgroundImageUrl?: string;
}
const { headline, subheadline, ctaText, ctaHref, backgroundImageUrl } = Astro.props;
const NO_IMAGE = "__NO_IMAGE__";
const desktopImg = (backgroundImageUrl && backgroundImageUrl !== NO_IMAGE) ? backgroundImageUrl : DEFAULT_HERO_DESKTOP;
const mobileImg  = DEFAULT_HERO_MOBILE;
---

<section data-eval-component="HeroCenter" class="hero-section">
  <div class="hero-bg">
    <img src={desktopImg} alt="" class="hero-img-desktop" loading="eager" />
    <img src={mobileImg}  alt="" class="hero-img-mobile"  loading="eager" />
    <div class="hero-gradient" />
    <div class="hero-wrapper">
      <h1 class="hero-h1">{headline ?? "Find the fitness plan that fits your lifestyle"}</h1>
      <p class="hero-subtext">{subheadline ?? "Our passionate coaching staff will help you reach any goal, inside and outside the gym."}</p>
      {ctaText && ctaHref && (
        <a href={ctaHref} class="hero-cta">
          <span class="hero-cta-arrow">▶</span> {ctaText}
        </a>
      )}
    </div>
  </div>
</section>

<style>
  .hero-section { position: relative; width: 100%; overflow: hidden; }
  .hero-bg { position: relative; width: 100%; min-height: 560px; }

  .hero-img-desktop {
    width: 100%;
    height: 100%;
    min-height: 560px;
    object-fit: cover;
    display: block;
  }
  .hero-img-mobile { display: none; }

  /* Dark gradient from left so text is readable */
  .hero-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(0,0,0,0.72) 0%, rgba(0,0,0,0.42) 50%, rgba(0,0,0,0.08) 100%);
  }

  /* Text sits absolutely over the image */
  .hero-wrapper {
    position: absolute;
    bottom: 60px;
    left: 60px;
    max-width: 580px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .hero-h1 {
    font-family: var(--modern-font-heading, 'Montserrat', sans-serif);
    font-size: 2.75rem;
    font-weight: 900;
    line-height: 1.05;
    color: #fff;
    margin: 0;
  }

  .hero-subtext {
    font-family: var(--modern-font-body, 'Barlow', sans-serif);
    font-size: 1rem;
    line-height: 1.6;
    color: rgba(255,255,255,0.88);
    margin: 0;
    max-width: 440px;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background-color: var(--modern-accent, #0464fc);
    color: #fff;
    font-family: var(--modern-font-heading, 'Montserrat', sans-serif);
    font-weight: 700;
    font-size: 1rem;
    padding: 14px 28px;
    border-radius: 6px;
    text-decoration: none;
    align-self: flex-start;
  }
  .hero-cta-arrow { font-size: 0.75rem; }

  @media (max-width: 768px) {
    .hero-img-desktop { display: none; }
    .hero-img-mobile  { display: block; width: 100%; min-height: 480px; object-fit: cover; }
    .hero-wrapper { left: 24px; right: 24px; bottom: 40px; max-width: none; }
    .hero-h1 { font-size: 2rem; }
  }

  @media (min-width: 1440px) {
    .hero-h1 { font-size: 3.5rem; }
    .hero-bg { min-height: 680px; }
    .hero-img-desktop { min-height: 680px; }
    .hero-wrapper { left: 120px; bottom: 80px; }
  }
</style>
