---
export interface Props {
  headline?: string;
  subheadline?: string;
  ctaText?: string;
  ctaHref?: string;
  backgroundImageUrl?: string;
}

const { headline, subheadline, ctaText, ctaHref, backgroundImageUrl } = Astro.props;
const hasImage = backgroundImageUrl && backgroundImageUrl !== "__NO_IMAGE__";
---

<section
  data-eval-component="HeroCenter"
  class="hero-center"
  style={hasImage ? `background-image: url(${backgroundImageUrl}); background-size: cover; background-position: center;` : ""}
>
  {hasImage && <div class="overlay" />}
  <div class="hero-content">
    {headline && <h1 class="headline">{headline}</h1>}
    {subheadline && <p class="subheadline">{subheadline}</p>}
    {ctaText && ctaHref && (
      <a href={ctaHref} class="cta-button">{ctaText}</a>
    )}
  </div>
</section>

<style>
  .hero-center {
    position: relative;
    background-color: var(--color-primary, rgb(241, 241, 241));
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: 60vh;
    padding: 120px 20px;
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.35) 0%, rgba(0,0,0,0.55) 100%);
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 800px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px; /* Increased vertical space between headline and cards */
    padding: 60px; /* More internal padding for card content */
    border-radius: 20px; /* More rounded */
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
    background-color: rgba(255, 255, 255, 0.9);
  }

  .headline {
    font-family: var(--font-heading, 'Montserrat', sans-serif);
    font-size: 3.5rem; /* Larger for headline */
    font-weight: 700; /* Expected: 700 */
    line-height: 1.1; /* Tighter for headline */
    letter-spacing: -0.02em;
    color: #333;
    margin: 0;
    text-align: center;
  }

  .subheadline {
    font-family: var(--font-body, 'Barlow', sans-serif);
    font-size: 1.1rem;
    line-height: 1.5;
    color: #555;
    margin: 0;
    max-width: 560px;
    text-align: center;
  }

  .cta-button {
    display: inline-block;
    padding: 18px 40px; /* More padding */
    background-color: var(--color-accent, #0464fc); /* Dark purple/black (using accent color as per design intent) */
    color: white; /* White */
    text-decoration: none;
    border-radius: 12px; /* More rounded */
    font-family: var(--font-heading, 'Montserrat', sans-serif);
    font-weight: bold;
    font-size: 1.05rem;
    transition: background-color 0.2s, transform 0.2s;
  }

  .cta-button:hover {
    background-color: color-mix(in srgb, var(--color-accent, #0464fc) 85%, black);
    transform: translateY(-2px);
  }

  @media (min-width: 768px) {
    .headline { font-size: 4.5rem; }
    .subheadline { font-size: 1.25rem; }
  }

  @media (min-width: 1440px) {
    .hero-center {
      min-height: 70vh;
      padding-bottom: 150px;
    }
    .headline { font-size: 5.5rem; }
    .subheadline { font-size: 1.4rem; }
    .cta-button { padding: 20px 45px; font-size: 1.15rem; }
  }
</style>