---
// "Everything You Need To Crush Your Fitness Goals"
// Source: dark navy section with blue icon cards

const DEFAULT_FEATURES = [
  { icon: "🏋️", label: "Group Classes" },
  { icon: "🤸", label: "Personal Training" },
  { icon: "💪", label: "Open Gym" },
  { icon: "🥗", label: "Nutrition Coaching" },
  { icon: "🎯", label: "Goal Setting" },
  { icon: "👥", label: "Community" },
];

export interface Props {
  headline?: string;
  items?: Array<{ icon?: string; label?: string; }>;
}

const { headline, items } = Astro.props;
const cards = (items && items.length > 0) ? items : DEFAULT_FEATURES;
---

<section data-eval-component="DarkFeatureGrid" class="dark-feature-grid">
  <div class="dfg-inner">
    <h2 class="dfg-headline">{headline ?? "Everything You Need To Crush Your Fitness Goals"}</h2>
    <div class="dfg-grid">
      {cards.map((item) => (
        <div class="dfg-card">
          <span class="dfg-icon">{item.icon ?? "⚡"}</span>
          <span class="dfg-label">{item.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .dark-feature-grid {
    background-color: #0d1b2a;
    padding: 80px 20px;
    color: #fff;
  }
  .dfg-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 48px;
    align-items: center;
    text-align: center;
  }
  .dfg-headline {
    font-family: var(--modern-font-heading, 'Montserrat', sans-serif);
    font-size: 2rem;
    font-weight: 900;
    color: #fff;
    margin: 0;
    line-height: 1.1;
  }
  .dfg-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    width: 100%;
  }
  .dfg-card {
    background: rgba(4, 100, 252, 0.12);
    border: 1px solid rgba(4, 100, 252, 0.25);
    border-radius: 8px;
    padding: 28px 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }
  .dfg-icon { font-size: 2.5rem; }
  .dfg-label {
    font-family: var(--modern-font-heading, 'Montserrat', sans-serif);
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
  }
  @media (min-width: 768px) {
    .dfg-grid { grid-template-columns: repeat(3, 1fr); }
    .dfg-headline { font-size: 2.5rem; }
  }
  @media (min-width: 1024px) {
    .dfg-grid { grid-template-columns: repeat(6, 1fr); gap: 20px; }
    .dfg-headline { font-size: 3rem; }
  }
</style>
