---
export interface ProgramCardsStickyProps {
  headline?: string;
  items: Array<{
    slug: string;
    name: string;
    coverImageUrl?: string;
    shortDescription?: string;
  }>;
}

const NO_IMAGE = "__NO_IMAGE__";
const { headline, items = [] } = Astro.props as ProgramCardsStickyProps;
---

<section data-eval-component="ProgramCardsSticky" class="program-cards-sticky">
  {headline && <h2 class="section-headline">{headline}</h2>}
  {headline && <p class="section-description">Discover a variety of programs tailored to your interests and needs. Each card provides a glimpse into what makes our offerings unique and impactful.</p>}
  <div class="card-grid">
    {items.map((item) => {
      const hasCover =
        !!item.coverImageUrl &&
        item.coverImageUrl !== NO_IMAGE &&
        !item.coverImageUrl.includes("placehold.co");
      return (
        <a
          href={`/programs/${item.slug}`}
          class="card"
          style={hasCover ? `background-image: url(${item.coverImageUrl})` : ""}
        >
          <h3 class="card-title">{item.name}</h3>
          {item.shortDescription && (
            <p class="card-desc">{item.shortDescription}</p>
          )}
        </a>
      );
    })}
  </div>
</section>

<style>
  .program-cards-sticky {
    padding-top: 100px; /* More vertical padding */
    padding-bottom: 100px; /* More vertical padding */
    padding-inline: 20px;
    background-color: #f5f5f5;
  }

  .section-headline {
    font-size: 3.5rem; /* Larger font size */
    font-weight: 800;
    text-align: center; /* Center for section title */
    margin-bottom: 20px; /* More space below section title */
    color: #111;
    line-height: 1.1;
    max-width: 800px; /* Constrained width */
    margin-left: auto;
    margin-right: auto;
  }

  .section-description {
    font-size: 1.25rem; /* Larger font size */
    text-align: center; /* Center for section subtitle */
    max-width: 700px; /* Constrained width */
    margin: 0 auto 60px auto; /* More space below section subtitle */
    color: #555;
  }

  .card-grid {
    display: grid;
    grid-template-columns: 1fr; /* Default to 1 column for small screens */
    gap: 30px; /* Spacing between cards */
    max-width: 1200px;
    margin: 0 auto;
  }

  .card {
    position: relative;
    min-height: 320px;
    background-size: cover;
    background-position: center;
    background-color: #e0e0e0;
    border-radius: 12px; /* Rounded corners for cards */
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-end;
    padding: 32px;
    color: white;
    overflow: hidden;
    text-decoration: none;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.15);
  }

  .card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.8) 0%, rgba(0, 0, 0, 0.1) 60%);
    z-index: 1;
  }

  .card-title {
    position: relative;
    z-index: 2;
    font-size: 1.8rem;
    font-weight: 700;
    margin: 0 0 8px;
    line-height: 1.3;
  }

  .card-desc {
    position: relative;
    z-index: 2;
    font-size: 1rem;
    opacity: 0.9;
    margin: 0;
    max-width: 45ch;
  }

  @media (min-width: 768px) {
    .card-grid {
      grid-template-columns: repeat(2, 1fr); /* 2 columns for medium screens */
    }
  }

  @media (min-width: 1024px) {
    .card-grid {
      grid-template-columns: repeat(3, 1fr); /* 3 columns for cards */
    }

    .card {
      min-height: 380px;
    }
  }
</style>