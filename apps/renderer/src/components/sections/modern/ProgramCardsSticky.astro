---
export interface ProgramCardsStickyProps {
  headline?: string;
  items: Array<{ slug: string; name: string; coverImageUrl?: string; shortDescription?: string; }>;
}
const NO_IMAGE = "__NO_IMAGE__";
const { headline, items = [] } = Astro.props as ProgramCardsStickyProps;
---

<section data-eval-component="ProgramCardsSticky" class="program-cards-sticky">
  {headline && <h2 class="section-headline">{headline}</h2>}
  <div class="card-grid">
    {items.map((item) => {
      const hasCover = !!item.coverImageUrl && item.coverImageUrl !== NO_IMAGE && !item.coverImageUrl.includes("placehold.co");
      return (
        <a href={`/programs/${item.slug}`} class="card" style={hasCover ? `background-image:url(${item.coverImageUrl})` : ""}>
          <div class="card-body">
            <h3 class="card-title">{item.name}</h3>
            {item.shortDescription && <p class="card-desc">{item.shortDescription}</p>}
            <span class="card-cta">Learn More</span>
          </div>
        </a>
      );
    })}
  </div>
</section>

<style>
  .program-cards-sticky {
    background-color: #f5f5f5;
    padding: 80px 20px;
  }
  .section-headline {
    font-family: var(--modern-font-heading, 'Montserrat', sans-serif);
    font-size: 2rem;
    font-weight: 900;
    color: #111;
    text-align: center;
    margin: 0 auto 48px;
    max-width: 800px;
    line-height: 1.1;
  }
  .card-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    max-width: 1200px;
    margin: 0 auto;
  }
  .card {
    display: block;
    position: relative;
    min-height: 300px;
    background-color: #d0d0d0;
    background-size: cover;
    background-position: center;
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    color: #fff;
  }
  .card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.08) 55%);
    z-index: 1;
  }
  .card-body {
    position: relative;
    z-index: 2;
    padding: 24px;
    height: 100%;
    min-height: 300px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 8px;
  }
  .card-title {
    font-family: var(--modern-font-heading, 'Montserrat', sans-serif);
    font-size: 1.5rem;
    font-weight: 800;
    margin: 0;
  }
  .card-desc {
    font-family: var(--modern-font-body, 'Barlow', sans-serif);
    font-size: 0.9rem;
    opacity: 0.9;
    margin: 0;
  }
  .card-cta {
    display: inline-block;
    margin-top: 8px;
    padding: 8px 20px;
    background-color: var(--modern-accent, #0464fc);
    border-radius: 4px;
    font-family: var(--modern-font-heading, 'Montserrat', sans-serif);
    font-size: 0.875rem;
    font-weight: 700;
    align-self: flex-start;
  }
  @media (min-width: 768px) { .card-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) {
    .card-grid { grid-template-columns: repeat(3, 1fr); gap: 32px; }
    .card { min-height: 360px; }
    .card-body { min-height: 360px; }
    .section-headline { font-size: 2.75rem; }
  }
</style>
