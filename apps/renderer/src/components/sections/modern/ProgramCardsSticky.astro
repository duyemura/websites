---
export interface ProgramCardsStickyProps {
  headline?: string;
  items: Array<{
    slug: string;
    name: string;
    coverImageUrl?: string;
    shortDescription?: string;
  }>;
}

const NO_IMAGE = "__NO_IMAGE__";
const { headline, items = [] } = Astro.props as ProgramCardsStickyProps;
---

<section data-eval-component="ProgramCardsSticky" class="program-cards-sticky">
  {headline && <h2 class="section-headline">{headline}</h2>}
  <div class="card-grid">
    {items.map((item) => {
      const hasCover =
        !!item.coverImageUrl &&
        item.coverImageUrl !== NO_IMAGE &&
        !item.coverImageUrl.includes("placehold.co");
      return (
        <div
          class="card"
          style={hasCover ? `background-image: url(${item.coverImageUrl})` : ""}
        >
          <h3 class="card-title">{item.name}</h3>
          {item.shortDescription && (
            <p class="card-desc">{item.shortDescription}</p>
          )}
        </div>
      );
    })}
  </div>
</section>

<style>
  .program-cards-sticky {
    padding: 48px 20px;
    background-color: #f7f7f7;
  }

  .section-headline {
    font-size: 2rem;
    font-weight: 700;
    text-align: center;
    margin-bottom: 32px;
    color: #111;
  }

  .card-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .card {
    position: relative;
    min-height: 300px;
    background-size: cover;
    background-position: center;
    background-color: #222;
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-end;
    padding: 24px;
    color: white;
    overflow: hidden;
  }

  .card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.75) 0%, rgba(0, 0, 0, 0.1) 60%);
    z-index: 1;
  }

  .card-title {
    position: relative;
    z-index: 2;
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 0 6px;
  }

  .card-desc {
    position: relative;
    z-index: 2;
    font-size: 0.95rem;
    opacity: 0.85;
    margin: 0;
    max-width: 40ch;
  }

  @media (min-width: 768px) {
    .card-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .card-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .card {
      min-height: 360px;
    }
  }
</style>
