---
interface Item {
  id: string;
  icon: string;
  title: string;
  position: {
    col: number;
    row: string;
  };
  background: string;
}

interface Props {
  items: Item[];
  imageUrls: string[];
}

const { items = [], imageUrls } = Astro.props;
---

<section data-eval-component="ProgramCardsSticky" class="program-cards-sticky">
  <div class="card-grid">
    {items.map((item, index) => (
      <div class="card" style={{ gridColumn: item.position?.col, gridRow: item.position?.row }}>
        {item.background === "image" && imageUrls[index] && (
          <img src={imageUrls[index]} alt={item.title} class="card-background-image" />
        )}
        <h3 class="card-title">{item.title}</h3>
      </div>
    ))}
  </div>
</section>

<style>
  .program-cards-sticky {
    position: relative;
    padding-top: 0px;
    padding-bottom: 0px;
    background-color: #f7f7f7; /* Assuming a light background for the section */
  }

  .card-grid {
    display: grid;
    grid-gap: 20px; /* Adjust as needed */
    padding: 20px; /* Padding around the grid */
    position: sticky;
    top: 0; /* Makes the grid sticky */
  }

  .card {
    position: relative;
    overflow: hidden;
    border-radius: 12px; /* Rounded corners for cards */
    min-height: 250px; /* Minimum height for cards */
    display: flex;
    align-items: flex-end;
    padding: 20px;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1); /* Subtle shadow */
  }

  .card-background-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  .card-title {
    position: relative;
    z-index: 2;
    color: #fff; /* White text for titles on images */
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5); /* Text shadow for readability */
  }

  /* Mobile Styles (375px base) */
  @media (max-width: 767px) {
    .card-grid {
      grid-template-columns: 1fr;
      grid-auto-rows: minmax(250px, auto);
      padding: 15px;
    }

    .card:nth-child(1) {
      grid-column: 1;
      grid-row: 1;
    }

    .card:nth-child(2) {
      grid-column: 1;
      grid-row: 2;
    }

    .card:nth-child(3) {
      grid-column: 1;
      grid-row: 3;
    }
  }

  /* Desktop Styles (1440px) */
  @media (min-width: 1024px) {
    .card-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: repeat(3, minmax(250px, auto));
      padding: 50px 100px; /* Adjust padding for desktop */
      height: 939px; /* Matches boundingBox height */
      align-content: start; /* Align grid items to the start */
    }

    .card:nth-child(1) {
      grid-column: 1;
      grid-row: 1;
    }

    .card:nth-child(2) {
      grid-column: 2;
      grid-row: 2;
    }

    .card:nth-child(3) {
      grid-column: 1;
      grid-row: 3;
    }

    .card-title {
      font-size: 2rem; /* Larger font for desktop */
    }
  }
</style>