---
// Items are ProgramContent objects from GymSiteContent:
// { slug, name, shortDescription, coverImageUrl, hero, ... }
export interface ProgramCardsStickyProps {
  id?: string;
  headline?: string;
  items?: Array<{
    slug?: string;
    name?: string;
    shortDescription?: string;
    coverImageUrl?: string;
  }>;
}

const { id, headline, items = [] } = Astro.props;
---

<section data-eval-component="ProgramCardsSticky" id={id} class="program-cards-sticky">
  {headline && <h2 class="section-headline">{headline}</h2>}
  <div class="program-cards-sticky-container">
    <div class="program-cards-sticky-grid">
      {items.map((item) => {
        const imageUrl = item.coverImageUrl && item.coverImageUrl !== "__NO_IMAGE__" ? item.coverImageUrl : undefined;
        return (
          <a
            href={item.slug ? `/programs/${item.slug}` : "#"}
            class="program-card"
            style={imageUrl ? `background-image: url(${imageUrl});` : ""}
          >
            <div class="program-card-overlay"></div>
            <h3 class="program-card-title">{item.name}</h3>
            {item.shortDescription && <p class="program-card-desc">{item.shortDescription}</p>}
          </a>
        );
      })}
    </div>
  </div>
</section>

<style>
  .program-cards-sticky {
    padding: 2rem 1rem;
  }

  .section-headline {
    text-align: center;
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
  }

  .program-cards-sticky-container {
    width: 100%;
    max-width: 100%;
  }

  .program-cards-sticky-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    padding: 0 1rem;
  }

  .program-card {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-start;
    padding: 1.5rem;
    border-radius: 0.75rem;
    background-size: cover;
    background-position: center;
    background-color: #1a1a1a;
    min-height: 15rem;
    color: white;
    overflow: hidden;
    text-decoration: none;
  }

  .program-card-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.1));
    z-index: 1;
  }

  .program-card-title {
    position: relative;
    z-index: 2;
    font-size: 1.5rem;
    line-height: 1.3;
    font-weight: 700;
    margin: 0 0 0.25rem;
  }

  .program-card-desc {
    position: relative;
    z-index: 2;
    font-size: 0.9rem;
    line-height: 1.4;
    margin: 0;
    opacity: 0.9;
  }

  @media (min-width: 768px) {
    .program-cards-sticky-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1200px) {
    .program-cards-sticky-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
