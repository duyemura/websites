];

// Default amenity labels matching the source template
const DEFAULT_LABELS = [
  "Weekend Workout Classes",
  "Virtual Fitness Programming",
  "Top of the Line Workout Equipment",
  "Lockers",
  "Personal Training Sessions",
  "Purified Water Dispenser",
];
---

<section data-section="amenities" data-section-tag="content-block" class="amenities-modern">
  <div class="amenities-inner">
    <h2 class="amenities-headline">{headline ?? "Everything You Need To Crush Your Fitness Goals"}</h2>
    <div class="amenities-grid">
      {SOURCE_ICONS.map((svg, i) => {
        const label = items?.[i]?.label ?? DEFAULT_LABELS[i] ?? "";
        return (
          <div class="amenity-card">
            <div class="amenity-icon" set:html={svg} />
            <h3 class="amenity-name">{label}</h3>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .amenities-modern {
    background: #0d1b2a;
    padding: 80px 20px;
  }
  .amenities-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 56px;
    align-items: center;
    text-align: center;
  }
  .amenities-headline {
    font-family: var(--modern-font-heading, 'Montserrat', sans-serif);
    font-size: 2rem;
    font-weight: 900;
    color: #fff;
    margin: 0;
    max-width: 700px;
    line-height: 1.1;
  }
  .amenities-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    width: 100%;
  }
  .amenity-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
    padding: 36px 24px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
  }
  .amenity-icon { flex-shrink: 0; }
  .amenity-name {
    font-family: var(--modern-font-heading, 'Montserrat', sans-serif);
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    margin: 0;
    text-align: left;
    line-height: 1.3;
  }
  @media (min-width: 640px) {
    .amenities-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (min-width: 1024px) {
    .amenities-headline { font-size: 2.5rem; }
  }
</style>
