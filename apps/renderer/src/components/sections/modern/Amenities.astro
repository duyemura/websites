---
import type { Feature } from "../../../types/gym-content";

const { headline, items } = Astro.props as { headline?: string; items: Feature[] };

// Source site icons (blue SVGs from Beta Gym template)
const DEFAULT_ICONS = ["🏋️","💻","⚡","🔒","🤸","💧"];
---

<section data-section="amenities" data-section-tag="content-block" class="amenities-modern">
  <div class="amenities-inner">
    <h2 class="amenities-headline">{headline ?? "Everything You Need To Crush Your Fitness Goals"}</h2>
    <div class="amenities-grid">
      {(items ?? []).map((f, i) => (
        <div class="amenity-card">
          <span class="amenity-icon">{f.icon || DEFAULT_ICONS[i % DEFAULT_ICONS.length]}</span>
          <h3 class="amenity-name">{f.label}</h3>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .amenities-modern {
    background: #f5f5f5;
    padding: 80px 20px;
  }
  .amenities-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 48px;
    align-items: center;
    text-align: center;
  }
  .amenities-headline {
    font-family: var(--modern-font-heading, 'Montserrat', sans-serif);
    font-size: 2rem;
    font-weight: 900;
    color: #111;
    margin: 0;
    max-width: 700px;
  }
  .amenities-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    width: 100%;
  }
  .amenity-card {
    background: #fff;
    border-radius: 8px;
    padding: 28px 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    border: 1px solid rgba(0,0,0,0.06);
  }
  .amenity-icon {
    font-size: 2.5rem;
    color: var(--modern-accent, #0464fc);
  }
  .amenity-name {
    font-family: var(--modern-font-heading, 'Montserrat', sans-serif);
    font-size: 0.975rem;
    font-weight: 700;
    color: #111;
    margin: 0;
    text-align: center;
    line-height: 1.3;
  }
  @media (min-width: 640px) {
    .amenities-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (min-width: 1024px) {
    .amenities-grid { grid-template-columns: repeat(6, 1fr); gap: 24px; }
    .amenities-headline { font-size: 2.5rem; }
  }
</style>
