---
import Hero from "../sections/Hero.astro";
import ValueProps from "../sections/ValueProps.astro";
import FeatureGrid from "../sections/FeatureGrid.astro";
import ProgramCards from "../sections/ProgramCards.astro";
import HowItWorks from "../sections/HowItWorks.astro";
import Testimonials from "../sections/Testimonials.astro";
import FAQ from "../sections/FAQ.astro";
import CTABand from "../sections/CTABand.astro";
import Location from "../sections/Location.astro";
import { content } from "../../lib/content";
const home = content.pages.home;
const { business } = content;
---
<Hero hero={home.hero} />
{home.valueProps?.length > 0 && <ValueProps items={home.valueProps} />}
{home.featuredPrograms?.length > 0 && <ProgramCards slugs={home.featuredPrograms} headline={home.programsHeadline} />}
{home.howItWorks?.length > 0 && <HowItWorks steps={home.howItWorks} headline={home.howItWorksHeadline} />}
{home.testimonials?.length > 0 && <Testimonials items={home.testimonials} />}
{home.features?.length > 0 && <FeatureGrid items={home.features} headline="Everything you need to crush your fitness goals" subheadline="Explore the training options and support that set us apart." />}
{home.communityProps?.length > 0 && <ValueProps items={home.communityProps} headline={home.communityHeadline} />}
<CTABand headline={home.trustHeadline} />
<Location />
<FAQ items={home.faq} />
<CTABand headline="The hardest step is always the first step." ctaLabel={business.primaryCta.label} ctaUrl={business.primaryCta.url} />
