---
// apps/renderer/src/components/pages/PageRenderer.astro
// Template-agnostic page body renderer.
//
// Consumes a TemplateSpec from the registry and renders the declared component
// sequence for a given pageKey. Components are imported statically so Astro can
// compile them; the resolver only determines which ones to render and what props
// to pass.

import { content } from "../../lib/content";
import { getRegisteredSpec } from "../../lib/template-registry";
import { resolvePageComponents, type AstroComponent } from "../../lib/template-resolver";

import Hero from "../sections/beanburito/Hero.astro";
import Programs from "../sections/beanburito/Programs.astro";
import Location from "../sections/beanburito/Location.astro";
import Benefits from "../sections/beanburito/Benefits.astro";
import IconCardGrid from "../sections/IconCardGrid.astro";
import CTABand from "../sections/beanburito/CTABand.astro";
import HowItWorks from "../sections/beanburito/HowItWorks.astro";
import Amenities from "../sections/beanburito/Amenities.astro";
import Community from "../sections/beanburito/Community.astro";
import Testimonials from "../sections/beanburito/Testimonials.astro";
import FAQ from "../sections/beanburito/FAQ.astro";
import IframeBand from "../sections/beanburito/IframeBand.astro";
import WhatIsIt from "../sections/beanburito/WhatIsIt.astro";
import WhatToExpect from "../sections/beanburito/WhatToExpect.astro";
import BlogGrid from "../sections/beanburito/BlogGrid.astro";
import PricingGrid from "../sections/PricingGrid.astro";
import RichContent from "../sections/RichContent.astro";
import Story from "../sections/beanburito/Story.astro";
import Team from "../sections/beanburito/Team.astro";
import TeamGrid from "../sections/TeamGrid.astro";

const COMPONENT_MAP: Record<string, AstroComponent> = {
  hero: Hero as unknown as AstroComponent,
  programs: Programs as unknown as AstroComponent,
  location: Location as unknown as AstroComponent,
  benefits: Benefits as unknown as AstroComponent,
  iconCardGrid: IconCardGrid as unknown as AstroComponent,
  ctaBand: CTABand as unknown as AstroComponent,
  valueProps: Benefits as unknown as AstroComponent,
  howItWorks: HowItWorks as unknown as AstroComponent,
  amenities: Amenities as unknown as AstroComponent,
  community: Community as unknown as AstroComponent,
  testimonials: Testimonials as unknown as AstroComponent,
  faq: FAQ as unknown as AstroComponent,
  iframeBand: IframeBand as unknown as AstroComponent,
  whatIsIt: WhatIsIt as unknown as AstroComponent,
  whatToExpect: WhatToExpect as unknown as AstroComponent,
  blogGrid: BlogGrid as unknown as AstroComponent,
  pricingGrid: PricingGrid as unknown as AstroComponent,
  richContent: RichContent as unknown as AstroComponent,
  story: Story as unknown as AstroComponent,
  team: TeamGrid as unknown as AstroComponent,
  teamBeanburito: Team as unknown as AstroComponent,
};

interface Props {
  /** Registry page key (e.g. "home", "about", "contact", "program"). */
  pageKey: string;
  /** Override the template theme from gym.json. */
  templateTheme?: string;
  /** Optional page data override. Used for array pages like program pages. */
  pageData?: Record<string, unknown>;
}

const { pageKey, templateTheme, pageData } = Astro.props;
const theme = templateTheme ?? content.meta.templateTheme ?? "baseline";
const spec = getRegisteredSpec(theme);
if (!spec) {
  throw new Error(`PageRenderer: unsupported template theme "${theme}"`);
}

const components = resolvePageComponents(spec, pageKey, content, COMPONENT_MAP, pageData);
if (components.length === 0) {
  throw new Error(`PageRenderer: no components resolved for pageKey "${pageKey}" in theme "${theme}"`);
}
---

{components.map(({ component: Component, props }) => (
  <Component {...props} />
))}
