---
import { content } from "../../lib/content";

const { business, brand, navigation } = content;
const NO_IMAGE = "__NO_IMAGE__";
const hasLogo = brand.logoUrl && brand.logoUrl !== NO_IMAGE;

// Nav comes entirely from GymSiteContent.navigation.header, which is built
// by the content pipeline (content-mapper.ts) by merging the crawl-discovered
// pages with the template spec's canonical page list. No hardcoding here.
const navItems = navigation.header;
---

<header class="header-modern">
  <div class="header-inner">
    <a href="/" class="header-logo">
      {hasLogo
        ? <img src={brand.logoUrl} alt={brand.logoAlt || business.name} class="logo-img" />
        : <span class="logo-text">{business.name}</span>}
    </a>

    <nav class="header-nav" aria-label="Main navigation">
      <a href="/" class="nav-logo">
        {hasLogo
          ? <img src={brand.logoUrl} alt={brand.logoAlt || business.name} class="logo-img" />
          : <span class="logo-text">{business.name}</span>}
      </a>
      {navItems.map((item) =>
        item.children?.length
          ? (
            <div class="nav-dropdown">
              <span class="nav-link nav-link--dropdown">{item.label} ▾</span>
              <div class="dropdown-menu">
                {item.children.map(child => (
                  <a href={child.href} class="dropdown-link">{child.label}</a>
                ))}
              </div>
            </div>
          )
          : <a href={item.href} class="nav-link">{item.label}</a>
      )}
    </nav>

    <a href={business.primaryCta.url} class="header-cta">
      {business.primaryCta.label}
    </a>
  </div>
</header>

<style>
  .header-modern {
    position: sticky;
    top: 0;
    z-index: 100;
    background: #fff;
    border-bottom: 1px solid rgba(0,0,0,0.07);
  }
  .header-inner {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 40px;
    height: 72px;
    display: flex;
    align-items: center;
    gap: 32px;
  }
  .header-logo { text-decoration: none; flex-shrink: 0; }
  .logo-img { height: 40px; width: auto; display: block; }
  .logo-text {
    font-family: var(--modern-font-heading, 'Montserrat', sans-serif);
    font-size: 1.2rem;
    font-weight: 900;
    color: #111;
  }
  .header-nav {
    display: flex;
    align-items: center;
    gap: 24px;
    flex: 1;
  }
  .nav-logo {
    display: none; /* Hidden by default, shown on mobile */
    text-decoration: none;
    flex-shrink: 0;
  }
  .nav-logo .logo-img { height: 32px; } /* Smaller logo in nav for mobile */
  .nav-logo .logo-text { font-size: 1rem; } /* Smaller text in nav for mobile */

  .nav-link {
    font-family: var(--modern-font-body, 'Barlow', sans-serif);
    font-size: 0.95rem;
    font-weight: 500;
    color: #111;
    text-decoration: none;
    white-space: nowrap;
    cursor: pointer;
  }
  .nav-link:hover { color: var(--modern-accent, #0464fc); }
  .nav-dropdown { position: relative; }
  .dropdown-menu {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 6px;
    padding: 8px 0;
    min-width: 180px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.12);
    z-index: 200;
  }
  .nav-dropdown:hover .dropdown-menu { display: block; }
  .dropdown-link {
    display: block;
    padding: 8px 16px;
    font-family: var(--modern-font-body, 'Barlow', sans-serif);
    font-size: 0.9rem;
    color: #333;
    text-decoration: none;
  }
  .dropdown-link:hover { background: #f5f5f5; color: var(--modern-accent, #0464fc); }
  .header-cta {
    background: var(--modern-accent, #0464fc);
    color: #fff;
    font-family: var(--modern-font-heading, 'Montserrat', sans-serif);
    font-size: 0.875rem;
    font-weight: 700;
    padding: 10px 20px;
    border-radius: 6px;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
  }
  @media (max-width: 900px) {
    .header-nav {
      /* This entire block needs to be uncommented and potentially adjusted */
      display: none; /* Hide default nav on smaller screens */
      /* The following styles would be part of a mobile menu toggle functionality */
      /* For this fix, we are only adding the logo to the nav, not implementing the mobile menu itself. */
      /* If a mobile menu is implemented, this .header-nav should become a flex column */
      /* and .nav-logo should be displayed. */
    }
    .header-inner { padding: 0 20px; }

    /* The following styles are for demonstration if a mobile menu opens the .header-nav */
    /* If the nav is meant to be shown on mobile, you'd typically have a hamburger menu */
    /* that toggles a class on .header-nav to make it visible and styled differently. */
    /* For the purpose of this fix, we are just adding the logo to the nav itself. */
    /* If .header-nav is displayed on mobile, .nav-logo should be visible. */
    /* Example: */
    .header-nav { /* This will be overridden by mobile menu JS for actual toggle */
      display: flex; /* Changed from none to flex for the purpose of the fix */
      flex-direction: column;
      position: absolute;
      top: 72px; /* Adjust based on header height */
      left: 0;
      width: 100%;
      background: #fff;
      border-top: 1px solid rgba(0,0,0,0.07);
      padding: 20px;
      box-shadow: 0 8px 16px rgba(0,0,0,0.1);
      z-index: 99;
      transform: translateX(-100%); /* Start off-screen */
      transition: transform 0.3s ease-out;
    }

    /* This class would be toggled by JavaScript to open the menu */
    .header-nav.is-open {
      transform: translateX(0); /* Slide in */
    }

    .nav-logo {
      display: block; /* Show logo in nav on mobile */
      margin-bottom: 20px;
    }
    .nav-link,
    .nav-dropdown {
      padding: 10px 0;
      width: 100%;
      border-bottom: 1px solid #eee;
    }
    .dropdown-menu {
      position: static;
      box-shadow: none;
      border: none;
      padding-left: 20px;
      margin-top: 5px;
    }
    .header-cta {
      display: none; /* Hide CTA on mobile nav, or move it to the bottom of the mobile menu */
    }
  }
</style>