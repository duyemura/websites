---
import { content } from "../../lib/content";
const NO_IMAGE = "__NO_IMAGE__";
const { navigation, business, brand } = content;
const logoSrc = brand.logoUrl !== NO_IMAGE ? brand.logoUrl : undefined;
// Keep the header CTA compact so it never crowd out the last nav item.
const headerCtaLabel = business.primaryCta.label.length > 18 ? "Book intro" : business.primaryCta.label;
---
<header class="site-header fixed inset-x-0 top-0 z-50 bg-black/90 text-white backdrop-blur">
  <div class="mx-auto flex max-w-[90rem] items-center justify-between px-6 py-3 lg:px-10">
    <a href="/" class="relative flex h-12 items-center">
      {logoSrc
        ? <img src={logoSrc} alt={brand.logoAlt} class="header-logo h-full w-auto object-contain" loading="eager" />
        : <span class="header-logo-text font-heading text-sm font-black uppercase tracking-tight">{business.name}</span>
      }
    </a>

    <nav aria-label="Main" class="hidden items-center gap-3 pr-6 xl:flex xl:flex-wrap xl:justify-end 2xl:gap-5 2xl:pr-8">
      {navigation.header.map((item) => (
        <div class="group relative">
          <a
            href={item.href}
            aria-haspopup={item.children ? "true" : undefined}
            class="header-nav-link flex items-center gap-1 px-2 py-3.5 font-heading text-xs font-bold uppercase tracking-tight transition hover:text-accent xl:text-sm 2xl:px-3"
          >
            {item.label}
            {item.children && (
              <svg width="10" height="6" viewBox="0 0 10 6" fill="currentColor" aria-hidden="true">
                <path d="M1 1l4 4 4-4" />
              </svg>
            )}
          </a>
          {item.children && (
            <ul class="absolute left-0 top-full z-20 hidden min-w-48 border border-black/10 bg-white py-2 shadow-xl group-hover:block group-focus-within:block">
              {item.children.map((c) => (
                <li>
                  <a href={c.href} class="block px-4 py-2 text-sm font-semibold uppercase tracking-tight text-black hover:bg-accent hover:text-white">
                    {c.label}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </div>
      ))}
    </nav>

    <div class="flex items-center gap-4">
      <a
        href={business.primaryCta.url}
        data-track="contact"
        class="header-cta cta-skew ml-2 hidden h-10 items-center border-2 border-[var(--color-accent)] bg-[var(--color-accent)] px-5 py-2 font-heading text-sm font-bold uppercase tracking-wide text-white transition hover:bg-transparent hover:text-white sm:inline-flex"
      >
        <span>{headerCtaLabel}</span>
      </a>

      <details class="group xl:hidden" data-mobile-menu>
        <summary class="header-nav-link cursor-pointer list-none px-2 py-1 font-heading text-sm font-bold uppercase tracking-wide" aria-label="Toggle main menu">
          <span class="group-open:hidden">Menu</span>
          <span class="hidden group-open:inline">Close</span>
        </summary>
        <nav aria-label="Mobile navigation" aria-hidden="true" class="mobile-menu fixed inset-x-0 top-[4.5rem] z-40 border-t border-black/10 px-6 pb-6 pt-4 shadow-xl">
          <ul class="space-y-1">
            {navigation.header.map((item) => (
              <li>
                <a href={item.href} class="block py-2 font-heading text-sm font-bold uppercase tracking-tight text-black">{item.label}</a>
                {item.children && item.children.map((c) => (
                  <a href={c.href} class="block py-1 pl-4 text-sm font-medium uppercase tracking-tight text-black/70">{c.label}</a>
                ))}
              </li>
            ))}
            <li>
              <a href={business.primaryCta.url} class="mt-3 inline-block bg-accent px-5 py-2.5 font-heading text-sm font-bold uppercase tracking-wide text-white" data-track="contact">
                {business.primaryCta.label}
              </a>
            </li>
          </ul>
        </nav>
      </details>
    </div>
  </div>

  <script is:inline>
    (function () {
      var header = document.querySelector('.site-header');
      if (header) {
        function update() {
          header.classList.toggle('is-scrolled', window.scrollY > 40);
        }
        update();
        window.addEventListener('scroll', update, { passive: true });
      }

      var details = document.querySelector('[data-mobile-menu]');
      var menu = details && details.querySelector('.mobile-menu');
      if (details && menu) {
        function syncAria() {
          menu.setAttribute('aria-hidden', String(!details.open));
        }
        details.addEventListener('toggle', syncAria);
        syncAria();
      }
    })();
  </script>
</header>
