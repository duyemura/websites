---
const { title, subtitle, variant = "light" } = Astro.props as {
  title: string;
  subtitle?: string;
  variant?: "dark" | "light";
};
const titleClass =
  variant === "dark"
    ? "font-heading text-3xl font-bold text-white sm:text-4xl"
    : "font-heading text-3xl font-bold text-primary sm:text-4xl";
const subtitleClass = variant === "dark" ? "mt-3 text-lg text-white/80" : "mt-3 text-lg text-black/70";
---
<div class="mb-10 text-center">
  <h2 class={titleClass}>{title}</h2>
  {subtitle && <p class={subtitleClass}>{subtitle}</p>}
</div>
