---
import { content, absUrl } from "../../lib/content";
import type { PricingPlan } from "../../types/gym-content";
const { plans } = Astro.props as { plans: PricingPlan[] };
if (!plans?.length) return;
const { business } = content;
const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: `${business.name} Membership Plans`,
  itemListElement: plans
    .map((plan, i) => {
      const rawPrice = plan.price.replace(/[^0-9.]/g, "");
      if (!rawPrice) return null;
      return {
        "@type": "ListItem",
        position: i + 1,
        item: {
          "@type": "Offer",
          name: plan.name,
          ...(plan.description && { description: plan.description }),
          price: rawPrice,
          priceCurrency: "USD",
          availability: "https://schema.org/LimitedAvailability",
          seller: {
            "@type": "LocalBusiness",
            name: business.name,
            url: absUrl("/"),
          },
          url: absUrl("/pricing"),
        },
      };
    })
    .filter((item): item is NonNullable<typeof item> => item !== null),
};
---
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
