---
import { content, absUrl } from "../../lib/content";
import { NO_IMAGE } from "@ploy-gyms/shared-types/template-baseline";
const { name, path, description, image, areaServedOverride } = Astro.props as {
  name: string;
  path: string;
  description?: string;
  image?: string;
  areaServedOverride?: { "@type": string; name: string }[];
};
const { business, brand } = content;
const providerImage = brand.logoUrl && brand.logoUrl !== NO_IMAGE ? brand.logoUrl : undefined;
const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name,
  serviceType: name,
  ...(description && { description }),
  ...(image && { image }),
  provider: {
    "@type": "LocalBusiness",
    name: business.name,
    url: absUrl("/"),
    telephone: business.phone,
    address: {
      "@type": "PostalAddress",
      streetAddress: business.address.street,
      addressLocality: business.address.city,
      addressRegion: business.geo.stateAbbr,
      postalCode: business.address.zip,
      addressCountry: "US",
    },
    ...(providerImage && { image: providerImage }),
  },
  // Deduplicate cities in case primary city also appears in serviceArea
  areaServed: areaServedOverride ?? Array.from(new Set([business.geo.city, ...(business.serviceArea ?? [])]))
    .map((c) => ({ "@type": "City", name: c })),
  url: absUrl(path),
};
---
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
