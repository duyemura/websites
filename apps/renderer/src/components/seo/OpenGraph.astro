---
import { content, absUrl } from "../../lib/content";
const NO_IMAGE = "__NO_IMAGE__";
const { title, description, path, image } = Astro.props as { title: string; description: string; path: string; image?: string };
const url = absUrl(path);
// Prefer the explicit hero/cover image; fall back to homepage hero (1600×900). If only a
// NO_IMAGE sentinel is available, omit the og:image tag instead of emitting an invalid URL.
const candidate = image ?? content.pages.home.hero.backgroundImageUrl;
const img = candidate !== NO_IMAGE ? candidate : undefined;
---
<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={url} />
{img && <meta property="og:image" content={img} />}
{img && <meta property="og:image:alt" content={title} />}
<meta property="og:site_name" content={content.business.name} />
<meta name="twitter:card" content={img ? "summary_large_image" : "summary"} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{img && <meta name="twitter:image" content={img} />}
