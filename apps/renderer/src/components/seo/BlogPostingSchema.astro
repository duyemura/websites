---
import { content, absUrl } from "../../lib/content";
const NO_IMAGE = "__NO_IMAGE__";
import type { BlogPost } from "../../types/gym-content";
const { post } = Astro.props as { post: BlogPost };
const blogImage = post.coverImageUrl && post.coverImageUrl !== NO_IMAGE ? post.coverImageUrl : undefined;
const schema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.title,
  datePublished: post.publishedAt,
  description: post.excerpt,
  ...(post.author && { author: { "@type": "Person", name: post.author } }),
  publisher: { "@type": "Organization", name: content.business.name },
  url: absUrl(`/blog/${post.slug}`),
  ...(blogImage && { image: blogImage }),
};
---
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
