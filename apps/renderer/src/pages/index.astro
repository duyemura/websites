---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSection from "../components/sections/HeroSection.astro";
---

<BaseLayout title="Beta Gym — Free intro session" description="Book your free 1-on-1 intro session at our CrossFit gym in SoHo, New York.">
  <HeroSection
    title="Train with purpose"
    subtitle="Book your free intro session at Beta Gym, SoHo's community-driven CrossFit box."
    cta={{ label: "Book a free session", href: "#book" }}
  />

  <section class="py-16 px-6 max-w-4xl mx-auto text-center">
    <h2 class="text-2xl font-bold">How it works</h2>
    <div class="mt-8 grid gap-6 sm:grid-cols-3">
      <div class="rounded-lg border p-6">
        <h3 class="font-semibold">1. Book</h3>
        <p class="mt-2 text-sm text-gray-600">Pick a time that works for you.</p>
      </div>
      <div class="rounded-lg border p-6">
        <h3 class="font-semibold">2. Train</h3>
        <p class="mt-2 text-sm text-gray-600">Meet a coach and get moving.</p>
      </div>
      <div class="rounded-lg border p-6">
        <h3 class="font-semibold">3. Join</h3>
        <p class="mt-2 text-sm text-gray-600">Pick the membership that fits.</p>
      </div>
    </div>
  </section>
</BaseLayout>
