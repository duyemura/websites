---
import GymLayout from "../layouts/GymLayout.astro";
import HomeBaseline from "../components/pages/HomeBaseline.astro";
import HomeImpact from "../components/pages/HomeImpact.astro";
import { content, geoTitle } from "../lib/content";
const home = content.pages.home;
const isImpact = content.meta.templateTheme === "impact";
---
<GymLayout title={geoTitle("Group Strength, Cardio Bootcamp & Personal Training")} description={home.hero.subheading} path="/" image={home.hero.backgroundImageUrl}>
  {isImpact ? <HomeImpact /> : <HomeBaseline />}
</GymLayout>
