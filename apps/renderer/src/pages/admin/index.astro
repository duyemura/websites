---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { AdminApp } from "../../components/admin/AdminApp";
---

<BaseLayout title="Milo admin" description="Test the AI site builder">
  <main class="mx-auto max-w-5xl px-6 py-12">
    <h1 class="text-3xl font-bold">Milo for gyms — admin</h1>
    <p class="mt-2 text-gray-600">Scrape a site, build pages, and preview the result.</p>

    <div class="mt-8 space-y-6">
      <AdminApp client:load />
    </div>
  </main>
</BaseLayout>
