---
import GymLayout from "../../layouts/GymLayout.astro";
import BreadcrumbSchema from "../../components/seo/BreadcrumbSchema.astro";
import Container from "../../components/ui/Container.astro";
const NO_IMAGE = "__NO_IMAGE__";
import PageRenderer from "../../components/pages/PageRenderer.astro";
import { content } from "../../lib/content";
import { getRegisteredSpec } from "../../lib/template-registry";
const { blog } = content.pages;
const { business, navigation } = content;
const posts = [...blog.posts].sort((a, b) => b.publishedAt.localeCompare(a.publishedAt));
const title = `Fitness Tips & News in ${business.geo.city}, ${business.geo.stateAbbr} | ${business.name}`;
const theme = content.meta.templateTheme ?? "baseline";
const spec = getRegisteredSpec(theme);
const hasBlogIndexPage = !!spec?.pages?.blogIndex;
const blogNavLabel = navigation.header.find((i) => i.href === "/blog")?.label ?? blog.heroHeadline ?? "Blog";
---
<GymLayout title={title} description={`Fitness tips, nutrition advice, and gym news from ${business.name} in ${business.geo.city}, ${business.geo.stateAbbr}.`} path="/blog">
  <Fragment slot="head"><BreadcrumbSchema crumbs={[{ name: blogNavLabel, path: "/blog" }]} /></Fragment>
  {hasBlogIndexPage ? (
    <PageRenderer pageKey="blogIndex" pageData={blog as unknown as Record<string, unknown>} />
  ) : (
    <section class="py-16">
      <Container>
        <h1 class="mb-10 text-center font-heading text-4xl font-bold text-primary">{blogNavLabel}</h1>
        <div class="mx-auto max-w-2xl space-y-10">
          {posts.map((post) => (
            <article class="overflow-hidden rounded-xl shadow">
              {post.coverImageUrl && post.coverImageUrl !== NO_IMAGE && (
                <a href={`/blog/${post.slug}`}><img src={post.coverImageUrl} alt={post.title} width="1200" height="630" loading="lazy" class="aspect-[1.91/1] w-full object-cover" /></a>
              )}
              <div class="p-6">
                {post.category && <span class="text-xs font-bold uppercase tracking-wide text-accent">{post.category}</span>}
                <h2 class="mt-1 font-heading text-2xl font-semibold text-primary"><a href={`/blog/${post.slug}`}>{post.title}</a></h2>
                <p class="mt-2 text-secondary">{post.excerpt}</p>
                <a href={`/blog/${post.slug}`} class="mt-3 inline-block font-semibold text-accent">Read more →</a>
              </div>
            </article>
          ))}
        </div>
      </Container>
    </section>
  )}
</GymLayout>
