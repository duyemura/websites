---
import GymLayout from "../../../layouts/GymLayout.astro";
import PageRenderer from "../../../components/pages/PageRenderer.astro";
import ServiceSchema from "../../../components/seo/ServiceSchema.astro";
import BreadcrumbSchema from "../../../components/seo/BreadcrumbSchema.astro";
import FAQSchema from "../../../components/seo/FAQSchema.astro";
import { content, programGeoHeadline } from "../../../lib/content";

export function getStaticPaths() {
  return content.pages.programs.map((p) => ({ params: { slug: p.slug }, props: { program: p } }));
}
const { program } = Astro.props;
const { business } = content;
const path = `/programs/${program.slug}`;
const headline = programGeoHeadline(program);
const title = `${program.name} in ${business.geo.city}, ${business.geo.stateAbbr} | ${business.name}`;

// Beanburito program pages keep a geo H1 above the hero, so the hero headline renders as h2.
const pageData = { ...program, hero: { ...program.hero, renderAsH1: false } };
---
<GymLayout title={title} description={program.shortDescription} path={path} image={program.coverImageUrl}>
  <Fragment slot="head">
    <ServiceSchema name={program.name} path={path} description={program.shortDescription} image={program.coverImageUrl} />
    <BreadcrumbSchema crumbs={[{ name: "Programs", path: "/programs" }, { name: program.name, path }]} />
    {(program.faq?.length ?? 0) > 0 && <FAQSchema items={program.faq} />}
  </Fragment>

  <!-- Geo H1 for local SEO; hero renders its heading as h2 -->
  <section class="bg-black pt-10 text-center">
    <div class="mx-auto max-w-[90rem] px-6 lg:px-10">
      <h1 class="font-heading text-2xl font-semibold text-white">{headline}</h1>
    </div>
  </section>
  <PageRenderer pageKey="program" pageData={pageData} />
</GymLayout>
