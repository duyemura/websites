---
import GymLayout from "../../../layouts/GymLayout.astro";
import Hero from "../../../components/sections/Hero.astro";
import HowItWorks from "../../../components/sections/HowItWorks.astro";
import Testimonials from "../../../components/sections/Testimonials.astro";
import FAQ from "../../../components/sections/FAQ.astro";
import CTABand from "../../../components/sections/CTABand.astro";
import Location from "../../../components/sections/Location.astro";
import ServiceSchema from "../../../components/seo/ServiceSchema.astro";
import BreadcrumbSchema from "../../../components/seo/BreadcrumbSchema.astro";
import FAQSchema from "../../../components/seo/FAQSchema.astro";
import Container from "../../../components/ui/Container.astro";
import SectionHeading from "../../../components/ui/SectionHeading.astro";
import { content } from "../../../lib/content";

export function getStaticPaths() {
  const { business, pages } = content;
  // All cities: primary city + service area
  const cities = [
    business.geo.city,
    ...(business.serviceArea ?? []),
  ];
  return pages.programs.flatMap((program) =>
    cities.map((city) => {
      const citySlug = city.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "");
      return {
        params: { slug: program.slug, city: citySlug },
        props: { program, city, citySlug },
      };
    })
  );
}

const { program, city, citySlug } = Astro.props;
const { business } = content;
const path = `/programs/${program.slug}/${citySlug}`;
const geoHeadline = `${program.name} in ${city}, ${business.geo.stateAbbr}`;
const title = `${geoHeadline} | ${business.name}`;
const description = `${program.name} classes in ${city}, ${business.geo.stateAbbr}. ${program.shortDescription || `${business.name} serves members from ${city} with expert coaching and welcoming community.`}`.slice(0, 157);
---

<GymLayout title={title} description={description} path={path} canonicalPath={`/programs/${program.slug}`} image={program.coverImageUrl}>
  <Fragment slot="head">
    <ServiceSchema
      name={`${program.name} in ${city}`}
      path={path}
      description={program.shortDescription}
      image={program.coverImageUrl}
      areaServedOverride={[{ "@type": "City", name: city }]}
    />
    <BreadcrumbSchema
      crumbs={[
        { name: "Programs", path: "/programs" },
        { name: program.name, path: `/programs/${program.slug}` },
        { name: city, path },
      ]}
    />
    {(program.faq?.length ?? 0) > 0 && <FAQSchema items={program.faq} />}
  </Fragment>

  <!-- Geo H1 — city-specific for local SEO -->
  <Container>
    <h1 class="pt-10 text-center font-heading text-2xl font-semibold text-secondary">
      {geoHeadline}
    </h1>
  </Container>
  <Hero hero={program.hero} h1={false} />

  <!-- Geo intro callout -->
  <section class="bg-white py-10">
    <Container>
      <p class="mx-auto max-w-2xl text-center text-lg text-secondary">
        {business.name} serves members from {city} and the surrounding {business.geo.city} area.
        {program.shortDescription}
      </p>
    </Container>
  </section>

  {program.whatIsIt?.body && (
    <section data-section="whatIsIt" data-section-tag="content-block" class="py-16">
      <Container>
        <SectionHeading title={program.whatIsIt.headline} />
        <p class="mx-auto max-w-3xl text-center text-lg text-secondary">{program.whatIsIt.body}</p>
      </Container>
    </section>
  )}

  {program.whatMakesUsDifferent?.length > 0 && (
    <section data-section="whatMakesUsDifferent" data-section-tag="content-block" class="bg-slate-50 py-16">
      <Container>
        <SectionHeading title={`What makes our ${program.name} different?`} />
        <ul class="mx-auto max-w-2xl space-y-3">
          {program.whatMakesUsDifferent.map((d) => (
            <li class="flex gap-3"><span class="text-accent">✔</span><span>{d}</span></li>
          ))}
        </ul>
      </Container>
    </section>
  )}

  {program.whatToExpect?.steps?.length > 0 && (
    <section data-section="whatToExpect" data-section-tag="steps-band" class="py-16">
      <Container>
        <SectionHeading title={program.whatToExpect.headline} />
        <ol class="mx-auto flex max-w-3xl flex-wrap justify-center gap-4">
          {program.whatToExpect.steps.map((s, i) => (
            <li class="rounded-full bg-accent px-5 py-2 font-heading text-white">{i + 1}. {s}</li>
          ))}
        </ol>
      </Container>
    </section>
  )}

  {program.whoIsItFor?.length > 0 && (
    <section data-section="whoIsItFor" data-section-tag="content-block" class="bg-slate-50 py-16">
      <Container>
        <SectionHeading title={`Who is ${program.name} for?`} />
        <ul class="mx-auto max-w-2xl list-disc space-y-2 pl-6">
          {program.whoIsItFor.map((w) => <li>{w}</li>)}
        </ul>
      </Container>
    </section>
  )}

  <HowItWorks steps={program.gettingStarted} headline="Getting started" />
  <Testimonials items={program.testimonials} />
  <Location />
  <FAQ items={program.faq} />
  <CTABand
    headline={`Ready to start ${program.name} in ${city}?`}
    ctaLabel={business.primaryCta.label}
    ctaUrl={business.primaryCta.url}
  />
</GymLayout>
