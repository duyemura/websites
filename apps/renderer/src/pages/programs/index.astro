---
import GymLayout from "../../layouts/GymLayout.astro";
import PageRenderer from "../../components/pages/PageRenderer.astro";
import BreadcrumbSchema from "../../components/seo/BreadcrumbSchema.astro";
import { content } from "../../lib/content";
const { business, pages } = content;
const title = `Programs | ${business.name} in ${business.geo.city}, ${business.geo.stateAbbr}`;
const slugs = pages.programs.map((p) => p.slug);
const programNames = pages.programs.map((p) => p.name).join(", ");
const desc = `Explore programs at ${business.name} in ${business.geo.city}, ${business.geo.stateAbbr}: ${programNames}.`.slice(0, 157);

const pageData = {
  hero: {
    headline: "Our Programs",
    subheading: `${business.name} in ${business.geo.city}, ${business.geo.stateAbbr}`,
    intro: desc,
    ctaLabel: business.primaryCta.label,
    ctaUrl: business.primaryCta.url,
  },
  programsHeadline: "",
  programsSubheadline: "",
  featuredPrograms: slugs,
  ctaHeadline: "Not sure which program is right for you?",
};
---
<GymLayout title={title} description={desc} path="/programs">
  <Fragment slot="head">
    <BreadcrumbSchema crumbs={[{ name: "Programs", path: "/programs" }]} />
  </Fragment>
  <PageRenderer pageKey="programIndex" pageData={pageData} />
</GymLayout>
