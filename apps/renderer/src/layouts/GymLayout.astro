---
import { content, safeTrackingId } from "../lib/content";
import { NO_IMAGE } from "@ploy-gyms/shared-types/template-baseline";
import CanonicalMeta from "../components/seo/CanonicalMeta.astro";
import OpenGraph from "../components/seo/OpenGraph.astro";
import LocalBusinessSchema from "../components/seo/LocalBusinessSchema.astro";
import Tracking from "../components/tracking/Tracking.astro";
import Header from "../components/chrome/Header.astro";
import Footer from "../components/chrome/Footer.astro";
import StickyCTA from "../components/chrome/StickyCTA.astro";

interface Props {
  title?: string;
  description?: string;
  /** Path of this page, e.g. "/programs/group-strength" — used for canonical. */
  path: string;
  /**
   * Override the canonical URL path. Use when a page should canonicalize to a
   * different URL than its own (e.g. geo pages → parent program page).
   */
  canonicalPath?: string;
  /** OG image override (hero/cover). */
  image?: string;
}
const { title, description, path, canonicalPath, image } = Astro.props;
const { meta, business, brand } = content;
const gtmId = safeTrackingId(meta.googleTagManagerId);

const pageTitle = title ?? meta.defaultTitle;
const pageDescription = description ?? meta.defaultDescription;

const fontsHref =
  "https://fonts.googleapis.com/css2?family=" +
  encodeURIComponent(brand.headingFont) + ":wght@400;600;700" +
  "&family=" + encodeURIComponent(brand.bodyFont) + ":wght@400;500;700&display=swap";

// Sanitize before CSS injection — strip characters that could escape the :root block
// or inject closing tags. Brand values come from our content pipeline, not raw user
// input, but defense-in-depth matters before the API layer is fully validated.
const sanitize = (v: string) => v.replace(/[;<>{}'"\\]/g, "");
const rootCss = [
  `:root{`,
  `--color-primary: ${sanitize(brand.primaryColor)};`,
  `--color-secondary: ${sanitize(brand.secondaryColor)};`,
  `--color-accent: ${sanitize(brand.accentColor)};`,
  `--font-heading: '${sanitize(brand.headingFont)}',sans-serif;`,
  `--font-body: '${sanitize(brand.bodyFont)}',sans-serif;`,
  `}`,
].join("");
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href={fontsHref} />
    <CanonicalMeta path={canonicalPath ?? path} />
    <OpenGraph title={pageTitle} description={pageDescription} path={path} image={image} />
    <LocalBusinessSchema />
    <style is:inline set:html={rootCss}></style>
    <Tracking />
    {image && image !== NO_IMAGE && <link rel="preload" as="image" href={image} fetchpriority="high" />}
    <link rel="icon" href={brand.logoUrl !== NO_IMAGE ? brand.logoUrl : "/favicon.ico"} />
    <link rel="manifest" href="/site.webmanifest" />
    <slot name="head" />
  </head>
  <body class="font-body text-secondary bg-white">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded focus:bg-accent focus:px-4 focus:py-2 focus:text-white">Skip to main content</a>
    {gtmId && (
      <noscript>
        <iframe
          src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
          height="0" width="0" style="display:none;visibility:hidden"
        ></iframe>
      </noscript>
    )}
    <Header />
    <main id="main-content"><slot /></main>
    <Footer />
    <StickyCTA />
    <!-- Hidden entity anchor for AI crawlers (AEO). Off-screen, NOT display:none. -->
    <p class="sr-only">
      {business.name} is a gym located at {business.address.street} in {business.geo.city}, {business.geo.stateAbbr}. {business.tagline}
    </p>
  </body>
</html>
