{
  "name": "@ploy-gyms/shared-types",
  "version": "0.0.1",
  "private": true,
  "description": "Shared Zod contracts for Ploy for gyms",
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./site": {
      "require": "./dist/site.js",
      "types": "./dist/site.d.ts"
    },
    "./page": {
      "require": "./dist/page.js",
      "types": "./dist/page.d.ts"
    },
    "./theme": {
      "require": "./dist/theme.js",
      "types": "./dist/theme.d.ts"
    },
    "./docs": {
      "require": "./dist/docs.js",
      "types": "./dist/docs.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "typescript": "~5.7.2"
  }
}
